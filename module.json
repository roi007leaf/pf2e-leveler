{
  "id": "pf2e-leveler",
  "title": "PF2e Leveler",
  "description": "<p>Create, Plan and auto-apply character level-ups for Pathfinder 2E. Plan your entire build from level 1 to 20, with prerequisite validation and automatic application on level change.</p>",
  "version": "1.0.9",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "RoiLeaf",
      "discord": "RoiLeaf",
      "flags": {}
    }
  ],
  "esmodules": ["scripts/main.js"],
  "styles": [
    { "src": "styles/variables.css" },
    { "src": "styles/components.css" },
    { "src": "styles/level-planner.css" },
    { "src": "styles/feat-picker.css" },
    { "src": "styles/character-wizard.css" }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "json"],
      "paths": ["styles", "templates", "lang"]
    }
  },
  "relationships": {
    "systems": [
      {
        "id": "pf2e",
        "type": "system",
        "compatibility": {
          "minimum": "7.0.0",
          "verified": "7.7.1"
        }
      }
    ]
  },
  "url": "#{URL}#",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#"
}
