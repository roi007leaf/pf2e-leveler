<div class="pf2e-leveler item-picker">
  {{#if loading}}
  <div class="item-picker__loader">
    <i class="fa-solid fa-circle-notch fa-spin"></i>
  </div>
  {{else}}
  <div class="picker__browser">
    <aside class="picker__sidebar">
      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.CREATION.SEARCH"}}</div>
        <input type="text" class="picker__search"
               placeholder="{{localize 'PF2E_LEVELER.ITEM_PICKER.SEARCH'}}"
               data-action="searchItems"
               value="{{searchText}}">
      </div>

      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.FILTER_LEVEL"}}</div>
        <select class="picker__select" data-action="filterMaxLevel">
          <option value="">{{localize "PF2E_LEVELER.FEAT_PICKER.ANY_LEVEL"}}</option>
          {{#each levelOptions}}
          <option value="{{this.value}}" {{#if (eq this.value ../maxLevel)}}selected{{/if}}>{{localize "PF2E_LEVELER.FEAT_PICKER.MAX_LEVEL" level=this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.ITEM_PICKER.CATEGORY"}}</div>
        <div class="picker__source-list">
          {{#each categoryOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleCategory"
            data-category="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>

      {{#if showArmorFilters}}
      <div class="picker__filter-group">
        <div class="picker__filter-label picker__filter-label--row">
          <span>Armor Filters</span>
          <button type="button" class="picker__prereq-toggle" data-action="toggleArmorFilterLogic">{{#if (eq armorFilterLogic "and")}}AND{{else}}OR{{/if}}</button>
        </div>
        <div class="picker__source-list">
          {{#each armorFilterOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleArmorFilter"
            data-filter="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if showWeaponFilters}}
      <div class="picker__filter-group">
        <div class="picker__filter-label picker__filter-label--row">
          <span>Weapon Filters</span>
          <button type="button" class="picker__prereq-toggle" data-action="toggleWeaponFilterLogic">{{#if (eq weaponFilterLogic "and")}}AND{{else}}OR{{/if}}</button>
        </div>
        <div class="picker__source-list">
          {{#each weaponFilterOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleWeaponFilter"
            data-filter="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.SPELLS.TRAIT_FILTER"}}</div>
        <div class="wizard-trait-input spell-picker__trait-input picker__trait-autocomplete-wrap">
          <input type="text" class="wizard-trait-input__field" placeholder="{{localize 'PF2E_LEVELER.SPELLS.TRAIT_FILTER'}}" data-action="traitInput" autocomplete="off">
          <button type="button" class="picker__prereq-toggle" data-action="toggleTraitLogic">{{#if (eq traitLogic "and")}}AND{{else}}OR{{/if}}</button>
          <ul class="picker__trait-autocomplete" data-role="trait-autocomplete"></ul>
        </div>
        <div class="picker__source-list" data-role="selected-trait-chips" style="margin-top: 8px;{{#unless selectedTraitChips.length}} display: none;{{/unless}}">
          {{#each selectedTraitChips}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleTraitChip"
            data-trait="{{this.value}}">
            <span>{{this.label}}</span>
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
          {{/each}}
        </div>
      </div>

      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.FILTER_RARITY"}}</div>
        <div class="picker__source-list">
          {{#each rarityOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleRarityChip"
            data-rarity="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>

      {{#if sourceOptions.length}}
      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SUMMARY"}}</div>
        <div class="picker__source-list">
          {{#each sourceOptions}}
          <button
            type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleCompendiumSource"
            data-package="{{this.key}}"
            data-tooltip="{{this.key}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </aside>

    <section class="picker__results">
      <div class="picker__results-header">
        <div class="picker__results-label">{{localize "PF2E_LEVELER.ITEM_PICKER.EQUIPMENT"}}</div>
        <div class="spell-picker__results-meta">
          {{#if multiSelect}}
          <div class="spell-picker__selected-count">{{format "PF2E_LEVELER.SPELLS.SELECTED_COUNT" count=selectedCount}}</div>
          <button type="button" class="item-option__select-btn spell-picker__bulk-btn" data-action="toggleSelectAll" {{#unless filteredCount}}disabled{{/unless}}>
            {{#if allVisibleSelected}}
              {{localize "PF2E_LEVELER.SPELLS.DESELECT_ALL"}}
            {{else}}
              {{localize "PF2E_LEVELER.SPELLS.SELECT_ALL"}}
            {{/if}}
          </button>
          <button type="button" class="item-option__select-btn spell-picker__confirm-btn" data-action="confirmSelection" {{#unless selectedCount}}disabled{{/unless}}>
            {{localize "PF2E_LEVELER.SPELLS.ADD_SELECTED"}}
          </button>
          {{/if}}
          <div class="picker__results-count">{{#if capped}}{{renderedCount}}/{{filteredCount}}{{else}}{{filteredCount}}{{/if}}</div>
        </div>
      </div>

      <div class="item-list">
        {{#each items}}
        <div class="item-option {{#if this._levelerSelected}}spell-option--selected{{/if}}" data-uuid="{{this.uuid}}">
          <img class="item-option__img" src="{{this.img}}" alt="">
          <div class="item-option__info">
            <div class="item-option__header">
              <span class="item-option__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
              <span class="item-option__level">Lv {{this.itemLevel}}</span>
              {{#if this.priceLabel}}<span class="item-option__level">{{this.priceLabel}}</span>{{/if}}
            </div>
            <div class="item-option__traits">
              <span class="tag tag--muted">{{this.category}}</span>
              {{#each this.equipmentTags}}
              <span class="tag tag--info">{{this}}</span>
              {{/each}}
              {{#each this.traits}}
              <span class="tag tag--muted">{{this}}</span>
              {{/each}}
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}}">{{this.rarity}}</span>
              {{/if}}
            </div>
          </div>
          <div class="item-option__actions">
            <button type="button" class="item-option__select-btn" data-action="selectItem" data-uuid="{{this.uuid}}">
              {{#if ../multiSelect}}
                {{#if this._levelerSelected}}
                  {{localize "PF2E_LEVELER.UI.SELECTED"}}
                {{else}}
                  {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
                {{/if}}
              {{else}}
                {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
              {{/if}}
            </button>
          </div>
        </div>
        {{else}}
        <div class="planner-empty" style="padding: 2rem;">
          <p>{{localize "PF2E_LEVELER.FEAT_PICKER.NO_RESULTS"}}</p>
        </div>
        {{/each}}
        {{#if capped}}
        <div class="item-picker__cap-notice">{{localize "PF2E_LEVELER.ITEM_PICKER.SHOWING_PARTIAL"}} {{renderedCount}} / {{filteredCount}}</div>
        {{/if}}
      </div>
    </section>
  </div>

  {{/if}}
</div>
