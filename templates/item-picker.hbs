<div class="pf2e-leveler item-picker">
  {{#if loading}}
  <div class="item-picker__loader">
    <i class="fa-solid fa-circle-notch fa-spin"></i>
  </div>
  {{else}}
  <div class="picker__browser">
    <aside class="picker__sidebar">
      <div class="picker__filter-group picker__filter-group--compact">
        <input type="text" class="picker__search"
               placeholder="{{localize 'PF2E_LEVELER.ITEM_PICKER.SEARCH'}}"
               data-action="searchItems"
               value="{{searchText}}">
      </div>

      <div class="picker__filter-group picker__filter-group--compact">
        <div class="wizard-trait-input spell-picker__trait-input picker__trait-autocomplete-wrap">
          <input type="text" class="wizard-trait-input__field" placeholder="{{localize 'PF2E_LEVELER.SPELLS.TRAIT_FILTER'}}" data-action="traitInput" autocomplete="off">
          <button type="button" class="picker__prereq-toggle" data-action="toggleTraitLogic">{{#if (eq traitLogic "and")}}AND{{else}}OR{{/if}}</button>
          <ul class="picker__trait-autocomplete" data-role="trait-autocomplete"></ul>
        </div>
        <div class="picker__source-list picker__source-list--compact" data-role="selected-trait-chips" {{#unless selectedTraitChips.length}}style="display:none"{{/unless}}>
          {{#each selectedTraitChips}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleTraitChip"
            data-trait="{{this.value}}">
            <span>{{this.label}}</span>
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
          {{/each}}
        </div>
      </div>

      <div class="picker__filter-group picker__filter-group--utility">
        <div class="picker__utility-row picker__utility-row--inline-label">
          <div class="picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.FILTER_LEVEL"}}</div>
          <select class="picker__select picker__select--compact" data-action="filterMaxLevel">
          <option value="">{{localize "PF2E_LEVELER.FEAT_PICKER.ANY_LEVEL"}}</option>
          {{#each levelOptions}}
          <option value="{{this.value}}" {{#if (eq this.value ../maxLevel)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
          </select>
        </div>
      </div>

      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.ITEM_PICKER.CATEGORY"}}</div>
        <div class="picker__source-list">
          {{#each categoryOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleCategory"
            data-category="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>

      {{#if showArmorFilters}}
      <div class="picker__filter-group picker__filter-group--collapsible" data-section="armor">
        <div class="picker__section-header">
          <button type="button"
                  class="picker__section-toggle picker__section-toggle--label"
                  data-action="toggleFilterSection"
                  data-section="armor"
                  aria-expanded="{{#if filterSections.armor.collapsed}}false{{else}}true{{/if}}">
            <span>Armor Filters</span>
          </button>
          <button type="button" class="picker__prereq-toggle picker__prereq-toggle--section" data-action="toggleArmorFilterLogic">{{#if (eq armorFilterLogic "and")}}AND{{else}}OR{{/if}}</button>
          <span class="picker__section-meta">
            <span class="picker__section-summary" data-section-summary="armor">
              {{#if filterSections.armor.activeCount}}({{filterSections.armor.summary}}){{/if}}
            </span>
          </span>
          <button type="button"
                  class="picker__section-toggle picker__section-toggle--chevron"
                  data-action="toggleFilterSection"
                  data-section="armor"
                  aria-expanded="{{#if filterSections.armor.collapsed}}false{{else}}true{{/if}}">
            <i class="fa-solid fa-chevron-down picker__section-chevron" aria-hidden="true"></i>
          </button>
        </div>
        {{#unless filterSections.armor.collapsed}}
        <div class="picker__section-body">
        <div class="picker__source-list picker__source-list--stacked">
          {{#each armorFilterOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleArmorFilter"
            data-filter="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
        </div>
        {{/unless}}
      </div>
      {{/if}}

      {{#if showWeaponFilters}}
      <div class="picker__filter-group picker__filter-group--collapsible" data-section="weapon">
        <div class="picker__section-header">
          <button type="button"
                  class="picker__section-toggle picker__section-toggle--label"
                  data-action="toggleFilterSection"
                  data-section="weapon"
                  aria-expanded="{{#if filterSections.weapon.collapsed}}false{{else}}true{{/if}}">
            <span>Weapon Filters</span>
          </button>
          <button type="button" class="picker__prereq-toggle picker__prereq-toggle--section" data-action="toggleWeaponFilterLogic">{{#if (eq weaponFilterLogic "and")}}AND{{else}}OR{{/if}}</button>
          <span class="picker__section-meta">
            <span class="picker__section-summary" data-section-summary="weapon">
              {{#if filterSections.weapon.activeCount}}({{filterSections.weapon.summary}}){{/if}}
            </span>
          </span>
          <button type="button"
                  class="picker__section-toggle picker__section-toggle--chevron"
                  data-action="toggleFilterSection"
                  data-section="weapon"
                  aria-expanded="{{#if filterSections.weapon.collapsed}}false{{else}}true{{/if}}">
            <i class="fa-solid fa-chevron-down picker__section-chevron" aria-hidden="true"></i>
          </button>
        </div>
        {{#unless filterSections.weapon.collapsed}}
        <div class="picker__section-body">
        <div class="picker__source-list picker__source-list--stacked">
          {{#each weaponFilterOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleWeaponFilter"
            data-filter="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
        </div>
        {{/unless}}
      </div>
      {{/if}}

      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.FILTER_RARITY"}}</div>
        <div class="picker__source-list" data-role="rarity-chips">
          {{#each rarityOptions}}
          <button type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleRarityChip"
            data-rarity="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>

      {{#if publicationOptions.length}}
      <div class="picker__filter-group picker__filter-group--collapsible" data-section="publications">
        <button type="button"
                class="picker__section-toggle"
                data-action="toggleFilterSection"
                data-section="publications"
                aria-expanded="{{#if filterSections.publications.collapsed}}false{{else}}true{{/if}}">
          <span>{{localize "PF2E_LEVELER.UI.PUBLICATIONS"}}</span>
          <span class="picker__section-meta">
            <span class="picker__section-summary" data-section-summary="publications">
              {{#if filterSections.publications.activeCount}}({{filterSections.publications.summary}}){{/if}}
            </span>
            <i class="fa-solid fa-chevron-down picker__section-chevron" aria-hidden="true"></i>
          </span>
        </button>
        {{#unless filterSections.publications.collapsed}}
        <div class="picker__section-body">
        <input type="text" class="picker__search picker__search--compact" placeholder="{{localize 'PF2E_LEVELER.UI.SEARCH_PUBLICATIONS'}}" data-action="searchPublications">
        <div class="picker__source-list picker__source-list--stacked">
          {{#each publicationOptions}}
          <button
            type="button"
            class="picker__source-chip picker__source-chip--publication {{#if this.selected}}selected{{/if}}"
            data-action="togglePublication"
            data-publication="{{this.key}}"
            data-publication-name="{{this.label}}"
            data-tooltip="{{this.key}}">
            <span class="picker__source-chip-label">{{this.label}}</span>
          </button>
          {{/each}}
        </div>
        </div>
        {{/unless}}
      </div>
      {{/if}}
    </aside>

    <section class="picker__results">
      <div class="picker__results-header">
        <div class="picker__results-label">{{localize "PF2E_LEVELER.ITEM_PICKER.EQUIPMENT"}}</div>
        <div class="spell-picker__results-meta">
          {{#if multiSelect}}
          <div class="spell-picker__selected-count">{{format "PF2E_LEVELER.SPELLS.SELECTED_COUNT" count=selectedCount}}</div>
          <button type="button" class="item-option__select-btn spell-picker__bulk-btn" data-action="toggleSelectAll" {{#unless filteredCount}}disabled{{/unless}}>
            {{#if allVisibleSelected}}
              {{localize "PF2E_LEVELER.SPELLS.DESELECT_ALL"}}
            {{else}}
              {{localize "PF2E_LEVELER.SPELLS.SELECT_ALL"}}
            {{/if}}
          </button>
          <button type="button" class="item-option__select-btn spell-picker__confirm-btn" data-action="confirmSelection" {{#unless selectedCount}}disabled{{/unless}}>
            {{localize "PF2E_LEVELER.SPELLS.ADD_SELECTED"}}
          </button>
          {{/if}}
          <div class="picker__results-count">{{#if capped}}{{renderedCount}}/{{filteredCount}}{{else}}{{filteredCount}}{{/if}}</div>
        </div>
      </div>

      <div class="item-list">
        {{#each items}}
        <div class="item-option {{#if this._levelerSelected}}spell-option--selected{{/if}} {{#if this.guidanceSelectionBlocked}}wizard-item--disallowed{{/if}}" data-uuid="{{this.uuid}}" data-selectable="{{#if this.guidanceSelectionBlocked}}false{{else}}true{{/if}}">
          <img class="item-option__img" src="{{this.img}}" alt="">
          <div class="item-option__info">
            <div class="item-option__header">
              <span class="item-option__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
              <span class="item-option__level">Lv {{this.itemLevel}}</span>
              {{#if this.priceLabel}}<span class="item-option__level">{{this.priceLabel}}</span>{{/if}}
            </div>
            <div class="item-option__traits">
              <span class="tag tag--muted">{{this.category}}</span>
              {{#each this.equipmentTags}}
              <span class="tag tag--info">{{this}}</span>
              {{/each}}
              {{#each this.traits}}
              <span class="tag tag--muted">{{this}}</span>
              {{/each}}
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}}">{{this.rarity}}</span>
              {{/if}}
              {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
              {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
              {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
            </div>
          </div>
          <div class="item-option__actions">
            <button type="button" class="item-option__select-btn" data-action="selectItem" data-uuid="{{this.uuid}}" {{#if this.guidanceSelectionBlocked}}disabled{{/if}} data-tooltip="{{#if this.isDisallowed}}{{this.guidanceSelectionTooltip}}{{/if}}">
              {{#if ../multiSelect}}
                {{#if this.guidanceSelectionBlocked}}
                  {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}
                {{else if this._levelerSelected}}
                  {{localize "PF2E_LEVELER.UI.SELECTED"}}
                {{else}}
                  {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
                {{/if}}
              {{else}}
                {{#if this.guidanceSelectionBlocked}}
                  {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}
                {{else}}
                  {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
                {{/if}}
              {{/if}}
            </button>
          </div>
        </div>
        {{else}}
        <div class="planner-empty" style="padding: 2rem;">
          <p>{{localize "PF2E_LEVELER.FEAT_PICKER.NO_RESULTS"}}</p>
        </div>
        {{/each}}
        {{#if capped}}
        <div class="item-picker__cap-notice">{{localize "PF2E_LEVELER.ITEM_PICKER.SHOWING_PARTIAL"}} {{renderedCount}} / {{filteredCount}}</div>
        {{/if}}
      </div>
    </section>
  </div>

  {{/if}}
</div>
