                    <span class="skill-btn__name">{{this.label}}</span>
                    <span class="skill-btn__tags">
                      {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
                      {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
                      {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
                    </span>
                  </span>
                  <span class="skill-btn__rank rank-text-{{this.nextRankName}}">→ {{titleCase this.nextRankName}}</span>
                </button>
                {{/each}}
              </div>
            </div>

            <div class="planned-spells" style="margin-top: var(--leveler-spacing-md);">
              <div class="section-header" style="font-size: var(--leveler-font-sm);">
                <i class="section-header__icon fa-solid fa-wand-sparkles"></i>
                {{localize "PF2E_LEVELER.SECTIONS.CUSTOM_SPELLS"}}
              </div>
              {{#if customSpellEntryOptions.length}}
              <div style="display: flex; flex-direction: column; gap: 8px; margin: 0 0 var(--leveler-spacing-sm);">
                {{#each customSpellEntryOptions}}
                <div class="feat-slot" style="display: flex; align-items: center; gap: 12px; padding: 10px 12px;">
                  <div class="feat-slot__meta" style="min-width: 0; flex: 1;">
                    <div class="feat-slot__name">{{this.label}}</div>
                    <div class="feat-slot__requirements">
                      {{#if this.tradition}}<span class="tag tag--muted tag--tiny">{{this.tradition}}</span>{{/if}}
                      {{#if this.prepared}}<span class="tag tag--muted tag--tiny">{{this.prepared}}</span>{{/if}}
                      {{#if this.abilityLabel}}<span class="tag tag--muted tag--tiny">{{this.abilityLabel}}</span>{{/if}}
                      {{#if this.isCustom}}<span class="tag tag--info tag--tiny">{{localize "PF2E_LEVELER.UI.PLANNED_ENTRY"}}</span>{{/if}}
                    </div>
                  </div>
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <button type="button" class="spell-add-btn" data-action="openCustomSpellPicker" data-rank="-1" data-entry-type="{{this.entryType}}" style="padding: 4px 12px;">
                      <i class="fa-solid fa-plus"></i> {{localize "PF2E_LEVELER.UI.ADD_CUSTOM_SPELL"}}
                    </button>
                    <button type="button" class="spell-add-btn" data-action="openCustomSpellPicker" data-rank="0" data-entry-type="{{this.entryType}}" style="padding: 4px 12px;">
                      <i class="fa-solid fa-plus"></i> {{localize "PF2E_LEVELER.UI.ADD_CUSTOM_CANTRIP"}}
                    </button>
                    {{#if this.isCustom}}
                    <button type="button" class="spell-add-btn" data-action="removeCustomSpellEntry" data-key="{{this.customKey}}" style="padding: 4px 12px;">
                      <i class="fa-solid fa-xmark"></i> {{localize "PF2E_LEVELER.UI.REMOVE"}}
                    </button>
                    {{/if}}
                  </div>
                </div>
                {{/each}}
              </div>
              {{/if}}
              {{#each customSpellGroups}}
              <div class="planned-spells" style="margin-top: var(--leveler-spacing-sm);">
                <div class="section-header" style="font-size: var(--leveler-font-sm);">
                  <i class="section-header__icon fa-solid fa-book"></i>
                  {{this.label}}
                </div>
                <div class="feat-slot__requirements" style="margin-bottom: var(--leveler-spacing-xs);">
                  {{#if this.tradition}}<span class="tag tag--muted tag--tiny">{{this.tradition}}</span>{{/if}}
                  {{#if this.prepared}}<span class="tag tag--muted tag--tiny">{{this.prepared}}</span>{{/if}}
                  {{#if this.abilityLabel}}<span class="tag tag--muted tag--tiny">{{this.abilityLabel}}</span>{{/if}}
                  {{#if this.isCustom}}<span class="tag tag--info tag--tiny">{{localize "PF2E_LEVELER.UI.PLANNED_ENTRY"}}</span>{{/if}}
                </div>
                {{#each this.rankGroups}}
                <div class="picker__filter-label" style="margin-top: var(--leveler-spacing-sm);">{{this.label}}</div>
                <div class="wizard-spell-chips">
                  {{#each this.entries}}
                  <span class="wizard-spell-chip">
                    {{#if this.img}}
                    <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
                    {{/if}}
                    <span class="wizard-spell-chip__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                    <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="removeCustomSpell" data-index="{{this.index}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}"></i>
                  </span>
                  {{/each}}
                </div>
                {{/each}}
              </div>
              {{/each}}
              <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px;">
                <button type="button" class="spell-add-btn" data-action="addCustomSpellEntry" style="padding: 4px 12px;">
                  <i class="fa-solid fa-plus"></i> {{localize "PF2E_LEVELER.UI.ADD_SPELLCASTING_ENTRY"}}
                </button>
              </div>
            </div>

            <div class="planned-spells" style="margin-top: var(--leveler-spacing-md);">
              <div class="section-header" style="font-size: var(--leveler-font-sm);">
                <i class="section-header__icon fa-solid fa-shield-halved"></i>
                {{localize "PF2E_LEVELER.SECTIONS.CUSTOM_EQUIPMENT"}}
              </div>
              {{#each customEquipment}}
              <div class="tag tag--muted" style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: 999px; margin-bottom: 4px;">
                {{#if this.img}}
                <img src="{{this.img}}" alt="" style="width: 20px; height: 20px; border-radius: 4px; object-fit: cover;">
                {{/if}}
                <button type="button" data-action="viewItem" data-uuid="{{this.uuid}}" style="background: none; border: 0; padding: 0; color: inherit; font: inherit; cursor: pointer;">
                  {{this.name}}
                </button>
                <button type="button" data-action="removeCustomEquipment" data-index="{{this.index}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}" style="background: none; border: 0; padding: 0; color: inherit; cursor: pointer;">
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
              {{/each}}
              <div style="margin-top: 4px;">
                <button type="button" class="spell-add-btn" data-action="openCustomEquipmentPicker" style="padding: 4px 12px;">
                  <i class="fa-solid fa-plus"></i> {{localize "PF2E_LEVELER.EQUIPMENT.ADD"}}
                </button>
              </div>
            </div>
          </div>
          {{/if}}
        </div>
        {{/if}}

        {{#if showABP}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-gem"></i>
            {{localize "PF2E_LEVELER.SECTIONS.ABP_POTENCY"}}
          </div>
          <div class="level-section__body">
            <div class="abp-info">
              {{#if abpHasNew}}
              <span class="tag tag--info">{{localize "PF2E_LEVELER.ABP.NEW_POTENCY"}}</span>
              {{/if}}
              {{#if abpHasUpgrade2}}
              <span class="tag tag--info">{{localize "PF2E_LEVELER.ABP.UPGRADE_TO_2"}}</span>
              {{/if}}
              {{#if abpHasUpgrade3}}
              <span class="tag tag--info">{{localize "PF2E_LEVELER.ABP.UPGRADE_TO_3"}}</span>
              {{/if}}
              <p class="abp-note">{{localize "PF2E_LEVELER.ABP.NOTE"}}</p>
            </div>
          </div>
        </div>
        {{/if}}

        {{#if showSpells}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-sparkles"></i>
            {{localize "PF2E_LEVELER.SECTIONS.SPELLCASTING"}}
            {{#if hasNewRank}}
              <span class="tag tag--success">{{format "PF2E_LEVELER.SPELLS.NEW_RANK" rank=newRank}}</span>
            {{/if}}
          </div>
          <div class="level-section__body">
            {{#if showCustomSpellRankReminder}}
            <div class="feat-slot__note" style="margin-bottom: var(--leveler-spacing-sm);">
              <i class="fa-solid fa-circle-info"></i>
              {{localize "PF2E_LEVELER.UI.CUSTOM_SPELL_RANK_REMINDER"}}
            </div>
            {{/if}}
            <table class="spell-slot-table">
              <thead>
                <tr>
                  <th>{{localize "PF2E_LEVELER.SPELLS.RANK"}}</th>
                  <th>{{localize "PF2E_LEVELER.SPELLS.SLOTS"}}</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {{#each spellSlots}}
                <tr class="{{#if this.isNew}}spell-slot-row--new{{else if this.changed}}spell-slot-row--changed{{/if}}">
                  <td class="spell-slot-rank">{{this.rank}}</td>
                  <td class="spell-slot-count">
                    {{#if (and ../hasRankSpellSelections this.hasNew)}}
                      <span class="spell-slot-new">{{this.planned}}/{{this.newSlots}} new</span>
                      <span class="spell-slot-breakdown">({{this.total}} total)</span>
                    {{else if this.hasNew}}
                      <span class="spell-slot-new">{{this.total}}</span>
                      <span class="spell-slot-breakdown">(+{{this.newSlots}} new)</span>
                    {{else}}
                      {{this.total}}
                    {{/if}}
                    {{#if this.isDual}}
                      <span class="spell-slot-breakdown">({{this.primary}} + {{this.secondary}})</span>
                    {{/if}}
                  </td>
                  <td>
                    {{#if (and ../hasRankSpellSelections this.hasNew)}}
                      <button type="button" class="spell-add-btn" data-action="openSpellPicker" data-rank="{{#if this.isCantrips}}0{{else}}{{this.rankNum}}{{/if}}" data-tooltip="{{localize 'PF2E_LEVELER.SPELLS.ADD'}}" {{#if this.isFull}}disabled{{/if}}>
                        <i class="fa-solid fa-plus"></i>
                      </button>
                    {{/if}}
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>

            {{#if showGrantedSpells}}
            <div class="planned-spells" style="margin-top: var(--leveler-spacing-sm);">
              <div class="section-header" style="font-size: var(--leveler-font-sm);">
                <i class="section-header__icon fa-solid fa-gift"></i>
                {{localize "PF2E_LEVELER.SPELLS.GRANTED"}}
              </div>
              {{#each grantedSpells}}
              <div class="feat-slot feat-slot--filled" style="border-color: var(--leveler-success);">
                <img class="feat-slot__icon" src="{{this.img}}" alt="" data-action="viewFeat" data-uuid="{{this.uuid}}">
                <span class="feat-slot__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                <span class="feat-slot__level">Rank {{this.rank}}</span>
              </div>
              {{/each}}
            </div>
            {{/if}}

            {{#if hasSpellbook}}
            <div class="planned-spells" style="margin-top: var(--leveler-spacing-sm);">
              <div class="section-header" style="font-size: var(--leveler-font-sm);">
                <i class="section-header__icon fa-solid fa-book"></i>
                {{format "PF2E_LEVELER.SPELLS.SPELLBOOK" selected=plannedSpellbookSelectionCount count=spellbookSelectionCount}}
              </div>
              <div class="wizard-spell-chips">
                {{#each plannedSpells}}
                <span class="wizard-spell-chip">
                  <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
                  <span class="wizard-spell-chip__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                  <span class="tag tag--muted tag--tiny">Rank {{this.displayRank}}</span>
                  <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="removeSpell" data-uuid="{{this.uuid}}" data-entry-type="{{this.entryType}}" data-rank="{{this.displayRank}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}"></i>
                </span>
                {{/each}}
              </div>
              {{#unless (gte plannedSpellbookSelectionCount spellbookSelectionCount)}}
              <button type="button" class="spell-add-btn" data-action="openSpellPicker" data-entry-type="primary" data-rank="-1" data-tooltip="{{localize 'PF2E_LEVELER.SPELLS.ADD_TO_SPELLBOOK_HINT'}}" style="margin-top: 4px; padding: 4px 12px;">
                <i class="fa-solid fa-plus"></i> {{localize "PF2E_LEVELER.SPELLS.ADD_TO_SPELLBOOK"}}
              </button>
              {{/unless}}

              {{#if spellbookCantripSelectionCount}}
              <div class="section-header" style="font-size: var(--leveler-font-sm); margin-top: var(--leveler-spacing-sm);">
                <i class="section-header__icon fa-solid fa-wand-sparkles"></i>
                {{format "PF2E_LEVELER.SPELLS.SPELLBOOK_CANTRIPS" selected=plannedSpellbookCantripCount count=spellbookCantripSelectionCount}}
              </div>
              <div class="wizard-spell-chips">
                {{#each plannedSpellbookCantripSpells}}
                <span class="wizard-spell-chip">
                  <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
                  <span class="wizard-spell-chip__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                  <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="removeSpell" data-uuid="{{this.uuid}}" data-entry-type="{{this.entryType}}" data-rank="{{this.displayRank}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}"></i>
                </span>
                {{/each}}
              </div>
              {{#unless (gte plannedSpellbookCantripCount spellbookCantripSelectionCount)}}
              <button type="button" class="spell-add-btn" data-action="openSpellPicker" data-entry-type="primary" data-rank="0" data-tooltip="{{localize 'PF2E_LEVELER.SPELLS.ADD_CANTRIP_TO_SPELLBOOK_HINT'}}" style="margin-top: 4px; padding: 4px 12px;">
                <i class="fa-solid fa-plus"></i> {{localize "PF2E_LEVELER.SPELLS.ADD_CANTRIP_TO_SPELLBOOK"}}
              </button>
              {{/unless}}
              {{/if}}
            </div>
            {{/if}}

            {{#each dedicationSpellSections}}
            <div class="planned-spells" style="margin-top: var(--leveler-spacing-md);">
              <div class="section-header" style="font-size: var(--leveler-font-sm);">
                <i class="section-header__icon fa-solid fa-book-atlas"></i>
                {{this.name}}
              </div>
              <div class="wizard-spell-chips">
                {{#each this.plannedSpells}}
                <span class="wizard-spell-chip">
                  <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
                  <span class="wizard-spell-chip__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                  <span class="tag tag--muted tag--tiny">Rank {{this.displayRank}}</span>
                  <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="removeSpell" data-uuid="{{this.uuid}}" data-entry-type="{{this.entryType}}" data-rank="{{this.displayRank}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}"></i>
                </span>
                {{/each}}
              </div>

              {{#if (or this.cantripSelectionCount this.plannedCantripCount)}}
              <div class="section-header" style="font-size: var(--leveler-font-sm); margin-top: var(--leveler-spacing-sm);">
                <i class="section-header__icon fa-solid fa-wand-sparkles"></i>
                {{this.tradition}} cantrips ({{this.plannedCantripCount}}/{{this.cantripSelectionCount}})
              </div>
              <div class="wizard-spell-chips">
                {{#each this.plannedCantripSpells}}
                <span class="wizard-spell-chip">
                  <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
                  <span class="wizard-spell-chip__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                  <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="removeSpell" data-uuid="{{this.uuid}}" data-entry-type="{{this.entryType}}" data-rank="{{this.displayRank}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}"></i>
                </span>
                {{/each}}
              </div>
              {{#if this.remainingCantripSelections}}
              <button type="button" class="spell-add-btn" data-action="openSpellPicker" data-entry-type="{{this.entryType}}" data-rank="0" style="margin-top: 4px; padding: 4px 12px;">
                <i class="fa-solid fa-plus"></i> Add Cantrips
              </button>
              {{/if}}
              {{/if}}

              {{#each this.rankRows}}
              <div class="section-header" style="font-size: var(--leveler-font-sm); margin-top: var(--leveler-spacing-sm);">
                <i class="section-header__icon fa-solid fa-sparkles"></i>
                {{this.label}} spells ({{this.planned}}/{{this.count}})
              </div>
              {{#unless this.isFull}}
              <button type="button" class="spell-add-btn" data-action="openSpellPicker" data-entry-type="{{../entryType}}" data-rank="{{this.rank}}" style="margin-top: 4px; padding: 4px 12px;">
                <i class="fa-solid fa-plus"></i> Add {{this.label}} Spell
              </button>
              {{/unless}}
              {{/each}}
            </div>
            {{/each}}

            {{#if plannedSpells.length}}
            {{#unless hasSpellbook}}
            <div class="planned-spells">
              <div class="section-header" style="font-size: var(--leveler-font-sm); margin-top: var(--leveler-spacing-sm);">
                <i class="section-header__icon fa-solid fa-book-sparkles"></i>
                {{localize "PF2E_LEVELER.SPELLS.PLANNED"}}
              </div>
              <div class="wizard-spell-chips">
                {{#each plannedSpells}}
                <span class="wizard-spell-chip">
                  <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
                  <span class="wizard-spell-chip__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                  <span class="tag tag--muted tag--tiny">Rank {{this.rank}}</span>
                  <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="removeSpell" data-uuid="{{this.uuid}}" data-entry-type="{{this.entryType}}" data-rank="{{this.rank}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}"></i>
                </span>
                {{/each}}
              </div>
            </div>
            {{/unless}}
            {{/if}}

            {{#if showFocusSpells}}
            <div class="planned-spells" style="margin-top: var(--leveler-spacing-sm);">
              <div class="section-header" style="font-size: var(--leveler-font-sm);">
                <i class="section-header__icon fa-solid fa-sun"></i>
                {{localize "PF2E_LEVELER.SPELLS.FOCUS"}}
                {{#if newFocusSpell}}<span class="tag tag--success tag--tiny">{{localize "PF2E_LEVELER.SPELLS.NEW_FOCUS"}}</span>{{/if}}
              </div>
              {{#each focusSpells}}
              <div class="feat-slot feat-slot--filled" style="{{#if this.isNew}}border-color: var(--leveler-success);{{/if}}">
                <img class="feat-slot__icon" src="{{this.img}}" alt="" data-action="viewFeat" data-uuid="{{this.uuid}}">
                <span class="feat-slot__name" data-action="viewFeat" data-uuid="{{this.uuid}}">{{this.name}}</span>
                <span class="tag tag--info tag--tiny">{{this.tier}}</span>
              </div>
              {{/each}}
            </div>
            {{/if}}
          </div>
        </div>
        {{/if}}

        {{#if showApparitions}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-ghost"></i>
            {{localize "PF2E_LEVELER.ANIMIST.APPARITIONS"}}
            <span class="tag {{#if (eq apparitionSelectedCount attunementSlots)}}tag--success{{else}}tag--info{{/if}}">{{format "PF2E_LEVELER.SPELLS.ATTUNEMENT_SLOTS" selected=apparitionSelectedCount count=attunementSlots}}</span>
            {{#if newFocusPool}}
              <span class="tag tag--info">{{format "PF2E_LEVELER.SPELLS.FOCUS_POOL" count=newFocusPool}}</span>
            {{/if}}
          </div>
          <div class="level-section__body">
            <div class="apparition-list">
              {{#each availableApparitions}}
              <div class="apparition-item {{#if this.selected}}apparition-item--selected{{else if this.disabled}}apparition-item--disabled{{/if}}"
                data-action="toggleApparition" data-slug="{{this.slug}}" data-max-slots="{{../attunementSlots}}">
                <i class="fa-solid fa-ghost"></i>
                <span>{{localize this.nameKey}}</span>
                {{#if this.uuid}}
                <i class="fa-solid fa-circle-info apparition-info" data-action="viewApparition" data-uuid="{{this.uuid}}"></i>
                {{/if}}
              </div>
              {{/each}}
            </div>
          </div>
        </div>
        {{/if}}

      {{else}}
        <div class="planner-empty">
          <i class="planner-empty__icon fa-solid fa-hat-wizard"></i>
          <p>{{localize "PF2E_LEVELER.UI.OPEN_PLANNER"}}</p>
        </div>
      {{/if}}
    {{else}}
      <div class="planner-empty">
        <i class="planner-empty__icon fa-solid fa-hat-wizard"></i>
        {{#if unsupportedClass}}
          <p>{{format "PF2E_LEVELER.UI.UNSUPPORTED_CLASS" className=actorClassName}}</p>
        {{else}}
          <p>{{localize "PF2E_LEVELER.UI.NO_CLASS"}}</p>
        {{/if}}
      </div>
    {{/if}}
    {{#if sequentialMode}}
    <div class="sequential-controls">
      <div class="sequential-progress">
        {{format "PF2E_LEVELER.UI.SEQUENTIAL_PROGRESS" current=sequentialCurrentLevel target=sequentialTargetLevel}}
      </div>
      {{#if showNextLevel}}
      <button type="button" class="sequential-btn sequential-btn--next" data-action="sequentialNextLevel">
        {{localize "PF2E_LEVELER.UI.NEXT_LEVEL"}} <i class="fa-solid fa-arrow-right"></i>
      </button>
      {{else if showFinishSequential}}
      <button type="button" class="sequential-btn sequential-btn--finish" data-action="sequentialFinish">
        <i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.UI.FINISH_PLANNING"}}
      </button>
      {{/if}}
    </div>
    {{/if}}
  </div>
</div>
