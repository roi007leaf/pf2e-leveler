<div class="pf2e-leveler level-planner">
  {{#if isImportingPlan}}
  <div class="compendium-manager__loading">
    <div class="wizard-loading__card compendium-manager__loadingCard">
      <div class="wizard-loading__spinner" aria-hidden="true"></div>
      <div class="wizard-loading__title">{{localize "PF2E_LEVELER.UI.IMPORTING_PLAN_TITLE"}}</div>
      <div class="wizard-loading__text">{{localize "PF2E_LEVELER.UI.IMPORTING_PLAN_HINT"}}</div>
    </div>
  </div>
  {{/if}}
  <div class="planner-sidebar">
    <div class="sidebar-header">
      {{localize "PF2E_LEVELER.UI.OPEN_PLANNER"}}
    </div>
    <div class="sidebar-levels">
      {{#each sidebarLevels}}
      <div class="sidebar-level {{#if this.active}}active{{/if}} {{#if this.locked}}locked{{/if}}"
           data-action="selectLevel" data-level="{{this.level}}">
        <div class="sidebar-level__num">{{this.level}}</div>
        <div class="sidebar-level__summary" data-tooltip="{{this.summary}}">{{this.summary}}</div>
        {{#if this.isCurrent}}
          <span class="sidebar-level__current">{{localize "PF2E_LEVELER.UI.CURRENT"}}</span>
        {{/if}}
        {{#if (eq this.status "complete")}}
          <i class="sidebar-level__status sidebar-level__status--complete fa-solid fa-check-circle"></i>
        {{else if (eq this.status "warning")}}
          <i class="sidebar-level__status sidebar-level__status--warning fa-solid fa-exclamation-triangle"></i>
        {{else if (eq this.status "incomplete")}}
          <i class="sidebar-level__status sidebar-level__status--incomplete fa-solid fa-circle-xmark"></i>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{#if hasPlan}}
    <div class="sidebar-actions">
      <button type="button" class="sidebar-action-btn" data-action="exportPlan" data-tooltip="{{localize 'PF2E_LEVELER.UI.EXPORT'}}" {{#if isImportingPlan}}disabled{{/if}}>
        <i class="fa-solid fa-file-export"></i>
      </button>
      <button type="button" class="sidebar-action-btn" data-action="importPlan" data-tooltip="{{localize 'PF2E_LEVELER.UI.IMPORT'}}" {{#if isImportingPlan}}disabled{{/if}}>
        <i class="fa-solid fa-file-import"></i>
      </button>
      <button type="button" class="sidebar-action-btn sidebar-action-btn--danger" data-action="clearPlan" data-tooltip="{{localize 'PF2E_LEVELER.UI.CLEAR'}}" {{#if isImportingPlan}}disabled{{/if}}>
        <i class="fa-solid fa-trash"></i>
      </button>
    </div>
    {{/if}}
  </div>

  <div class="planner-content">
    {{#if hasPlan}}
      {{#if selectedLevel}}
        <div class="planner-content__header">
          <h2 class="planner-content__title">
            {{format "PF2E_LEVELER.UI.LEVEL" level=selectedLevel}}
          </h2>
          <button type="button" class="sidebar-action-btn sidebar-action-btn--danger planner-content__action" data-action="clearLevel" data-tooltip="{{localize 'PF2E_LEVELER.UI.CLEAR_LEVEL'}}">
            <i class="fa-solid fa-eraser"></i>
            {{localize "PF2E_LEVELER.UI.CLEAR_LEVEL"}}
          </button>
        </div>

        {{#if classFeatures.length}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-medal"></i>
            {{localize "PF2E_LEVELER.SECTIONS.CLASS_FEATURES"}}
          </div>
          <div class="level-section__body">
            {{#each classFeatures}}
            <div class="class-feature-item" data-action="viewFeat" data-uuid="{{this.uuid}}">
              {{#if this.img}}
              <img class="class-feature-item__icon" src="{{this.img}}" alt="">
              {{else}}
              <i class="class-feature-item__icon fa-solid fa-star"></i>
              {{/if}}
              <div class="class-feature-item__name">{{this.name}}</div>
            </div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{#if showBoosts}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-arrow-up"></i>
            {{format "PF2E_LEVELER.BOOSTS.TITLE" count=boostCount}} ({{selectedBoostCount}}/{{boostCount}})
          </div>
          <div class="level-section__body">
            <div class="boost-grid">
              {{#each attributes}}
              <button type="button"
                class="boost-btn {{#if this.selected}}selected{{/if}} {{#if this.partial}}partial{{/if}}"
                data-action="toggleBoost" data-attr="{{this.key}}"
                {{#if this.disabled}}disabled{{/if}}>
                <span class="boost-btn__abbr">{{this.label}}</span>
                {{#if this.selected}}
                  {{#if this.partial}}
                    {{#if this.completesPartial}}
                    <span class="boost-btn__change">+{{this.mod}} → +{{this.newMod}}</span>
                    {{else}}
                    <span class="boost-btn__change">+{{this.mod}} → +{{this.newMod}}(partial)</span>
                    {{/if}}
                  {{else}}
                  <span class="boost-btn__change">+{{this.mod}} → +{{this.newMod}}</span>
                  {{/if}}
                {{else}}
                  <span class="boost-btn__mod">+{{this.mod}}</span>
                {{/if}}
                {{#if this.partialLabel}}
                <i class="fa-solid fa-circle-info boost-btn__partial-info" data-tooltip="{{this.partialLabel}}" aria-hidden="true"></i>
                {{/if}}
              </button>
              {{/each}}
            </div>
            {{#if intelligenceBenefit}}
            <div class="feat-slot__note" style="margin-top: var(--leveler-spacing-md);">
              <i class="fa-solid fa-circle-info"></i>
              {{#if intelligenceBenefit.gainsSingle}}
              {{localize "PF2E_LEVELER.CREATION.INTELLIGENCE_BONUS_HINT_SINGLE"}}
              {{else}}
              {{format "PF2E_LEVELER.CREATION.INTELLIGENCE_BONUS_HINT_MULTI" count=intelligenceBenefit.count}}
              {{/if}}
            </div>
            {{/if}}
          </div>
        </div>
        {{/if}}

        {{#if intBonusSkillOptions}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-brain"></i>
            {{format "PF2E_LEVELER.CREATION.INTELLIGENCE_BONUS_SKILLS" selected=intBonusSkillCount count=intelligenceBenefit.count}}
          </div>
          <div class="level-section__body">
            <div class="skill-btn-grid">
              {{#each intBonusSkillOptions}}
              <button type="button"
                class="skill-btn skill-btn--stacked {{#if this.selected}}selected{{/if}} {{#if this.isDisallowed}}wizard-item--disallowed{{/if}}"
                data-action="toggleIntBonusSkill" data-skill="{{this.slug}}"
                {{#if (or this.disabled this.isDisallowed)}}disabled{{/if}}>
                <span class="skill-btn__content">
                  <span class="skill-btn__name">{{this.label}}</span>
                  <span class="skill-btn__tags">
                    {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
                    {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
                    {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
                  </span>
                </span>
              </button>
              {{/each}}
            </div>
          </div>
        </div>
        {{/if}}

        {{#if intBonusLanguageOptions}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-language"></i>
            {{format "PF2E_LEVELER.CREATION.INTELLIGENCE_BONUS_LANGUAGES" selected=intBonusLanguageCount count=intelligenceBenefit.count}}
          </div>
          <div class="level-section__body">
            <div class="skill-btn-grid">
              {{#each intBonusLanguageOptions}}
              <button type="button"
                class="skill-btn skill-btn--stacked {{#if this.selected}}selected{{/if}} {{#if this.isDisallowed}}wizard-item--disallowed{{/if}}"
                data-action="toggleIntBonusLanguage" data-language="{{this.slug}}"
                {{#if (or this.disabled this.isDisallowed)}}disabled{{/if}}>
                <span class="skill-btn__content">
                  <span class="skill-btn__name">{{this.label}}</span>
                  <span class="skill-btn__tags">
                    {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
                    {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
                    {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
                    {{#if this.suggested}}<span class="tag tag--info tag--tiny">{{localize "PF2E_LEVELER.CREATION.ANCESTRY_SUGGESTION"}}</span>{{/if}}
                    {{#if (notEqual this.rarity "common")}}
                    <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
                    {{/if}}
                  </span>
                </span>
              </button>
              {{/each}}
            </div>
          </div>
        </div>
        {{/if}}

        {{#if showClassFeat}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-book"></i>
            {{localize "PF2E_LEVELER.SECTIONS.CLASS_FEAT"}}
          </div>
          <div class="level-section__body">
            {{> featSlot feat=classFeat category="classFeats" level=selectedLevel}}
            {{#each classFeatChoiceSets}}
            <div class="feat-slot__note" style="margin-top: var(--leveler-spacing-md);">
              <i class="fa-solid fa-circle-info"></i>
              {{this.prompt}}
            </div>
            {{#if (eq this.choiceType "skill")}}
            <div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <button type="button" class="skill-btn {{#if this.selected}}selected{{/if}}" data-action="selectPlannedFeatChoice" data-category="classFeats" data-flag="{{../flag}}" data-value="{{this.value}}" data-grants-skill-training="{{#if ../grantsSkillTraining}}true{{else}}false{{/if}}" {{#if this.disabled}}disabled{{/if}}>
                <span class="skill-btn__name">{{this.label}}</span>
              </button>
              {{/each}}
            </div>
            {{else if (eq this.choiceType "language")}}
            <div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <button type="button" class="skill-btn skill-btn--stacked {{#if this.selected}}selected{{/if}} {{#if this.isDisallowed}}wizard-item--disallowed{{/if}}" data-action="selectPlannedFeatChoice" data-category="classFeats" data-flag="{{../flag}}" data-value="{{this.value}}" {{#if this.isDisallowed}}disabled{{/if}}>
                <span class="skill-btn__content">
                  <span class="skill-btn__name">{{this.label}}</span>
                  <span class="skill-btn__tags">
                    {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
                    {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
                    {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
                    {{#if (notEqual this.rarity "common")}}<span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>{{/if}}
                  </span>
                </span>
              </button>
              {{/each}}
            </div>
            {{else if (eq this.choiceType "lore")}}
            {{#if this.options.length}}
            <div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <button type="button" class="skill-btn {{#if this.selected}}selected{{/if}}" disabled>
                <span class="skill-btn__name">{{this.label}}</span>
              </button>
              {{/each}}
            </div>
            {{/if}}

            {{else}}
            <div class="wizard-item-grid wizard-item-grid--compact" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <div class="wizard-item {{#if this.selected}}wizard-item--taken{{/if}}">
                {{#if this.img}}
                <img src="{{this.img}}" alt="" class="wizard-item__img">
                {{/if}}
                <div class="wizard-item__info">
                  <span class="wizard-item__name wizard-item__name--static">{{this.label}}</span>
                </div>
                {{#if this.selected}}
                <span class="tag tag--success tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.UI.SELECTED"}}</span>
                {{else}}
                <button type="button" class="wizard-item__select" data-action="selectPlannedFeatChoice" data-category="classFeats" data-flag="{{../flag}}" data-value="{{this.value}}">
                  {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
                </button>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{#if showSkillFeat}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-wrench"></i>
            {{localize "PF2E_LEVELER.SECTIONS.SKILL_FEAT"}}
          </div>
          <div class="level-section__body">
            {{> featSlot feat=skillFeat category="skillFeats" level=selectedLevel}}
          </div>
        </div>
        {{/if}}

        {{#if showGeneralFeat}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-shield"></i>
            {{localize "PF2E_LEVELER.SECTIONS.GENERAL_FEAT"}}
          </div>
          <div class="level-section__body">
            {{> featSlot feat=generalFeat category="generalFeats" level=selectedLevel}}
            {{#each generalFeatChoiceSets}}
            <div class="feat-slot__note" style="margin-top: var(--leveler-spacing-md);">
              <i class="fa-solid fa-circle-info"></i>
              {{this.prompt}}
            </div>
            {{#if (eq this.choiceType "skill")}}
            <div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <button type="button" class="skill-btn {{#if this.selected}}selected{{/if}}" data-action="selectPlannedFeatChoice" data-category="generalFeats" data-flag="{{../flag}}" data-value="{{this.value}}" data-grants-skill-training="{{#if ../grantsSkillTraining}}true{{else}}false{{/if}}" {{#if this.disabled}}disabled{{/if}}>
                <span class="skill-btn__name">{{this.label}}</span>
              </button>
              {{/each}}
            </div>
            {{else if (eq this.choiceType "language")}}
            <div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <button type="button" class="skill-btn skill-btn--stacked {{#if this.selected}}selected{{/if}} {{#if this.isDisallowed}}wizard-item--disallowed{{/if}}" data-action="selectPlannedFeatChoice" data-category="generalFeats" data-flag="{{../flag}}" data-value="{{this.value}}" {{#if this.isDisallowed}}disabled{{/if}}>
                <span class="skill-btn__content">
                  <span class="skill-btn__name">{{this.label}}</span>
                  <span class="skill-btn__tags">
                    {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
                    {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
                    {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
                    {{#if this.suggested}}<span class="tag tag--info tag--tiny">{{localize "PF2E_LEVELER.CREATION.ANCESTRY_SUGGESTION"}}</span>{{/if}}
                    {{#if (notEqual this.rarity "common")}}<span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>{{/if}}
                  </span>
                </span>
              </button>
              {{/each}}
            </div>
            {{else if (eq this.choiceType "lore")}}
            {{#if this.options.length}}<div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">{{#each this.options}}<button type="button" class="skill-btn {{#if this.selected}}selected{{/if}}" disabled><span class="skill-btn__name">{{this.label}}</span></button>{{/each}}</div>{{/if}}

            {{else}}
            <div class="wizard-item-grid wizard-item-grid--compact" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <div class="wizard-item {{#if this.selected}}wizard-item--taken{{/if}}">
                {{#if this.img}}
                <img src="{{this.img}}" alt="" class="wizard-item__img">
                {{/if}}
                <div class="wizard-item__info">
                  <span class="wizard-item__name wizard-item__name--static">{{this.label}}</span>
                </div>
                {{#if this.selected}}
                <span class="tag tag--success tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.UI.SELECTED"}}</span>
                {{else}}
                <button type="button" class="wizard-item__select" data-action="selectPlannedFeatChoice" data-category="generalFeats" data-flag="{{../flag}}" data-value="{{this.value}}">
                  {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
                </button>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{/each}}
            {{#if showGeneralFeatAdoptedAncestry}}
            <div class="feat-slot__note" style="margin-top: var(--leveler-spacing-md);">
              <i class="fa-solid fa-circle-info"></i>
              {{localize "PF2E_LEVELER.UI.SELECT_ADOPTED_ANCESTRY"}}
            </div>
            <div class="wizard-item-grid wizard-item-grid--compact" style="margin-top: var(--leveler-spacing-sm);">
              {{#each generalFeatAdoptedAncestryOptions}}
              <div class="wizard-item {{#if this.selected}}wizard-item--taken{{/if}}">
                {{#if this.img}}
                <img src="{{this.img}}" alt="" class="wizard-item__img">
                {{/if}}
                <div class="wizard-item__info">
                  <span class="wizard-item__name wizard-item__name--static">{{this.label}}</span>
                </div>
                {{#if this.selected}}
                <span class="tag tag--success tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.UI.SELECTED"}}</span>
                {{else}}
                <button type="button"
                  class="wizard-item__select"
                  data-action="selectAdoptedAncestry"
                  data-value="{{this.value}}">
                  {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
                </button>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{#if showGeneralFeatGrantedAncestryFeat}}
            <div class="feat-slot__note" style="margin-top: var(--leveler-spacing-md);">
              <i class="fa-solid fa-circle-info"></i>
              {{format "PF2E_LEVELER.UI.GRANTED_BY_FEAT" featName=generalFeat.name}}
            </div>
            {{> featSlot feat=generalFeatGrantedAncestryFeat category="ancestryFeats" level=selectedLevel}}
            {{/if}}
          </div>
        </div>
        {{/if}}

        {{#if showAncestryFeat}}
        <div class="level-section">
          <div class="section-header">
            <i class="section-header__icon fa-solid fa-dna"></i>
            {{localize "PF2E_LEVELER.SECTIONS.ANCESTRY_FEAT"}}
          </div>
          <div class="level-section__body">
            {{> featSlot feat=ancestryFeat category="ancestryFeats" level=selectedLevel}}
            {{#each ancestryFeatChoiceSets}}
            <div class="feat-slot__note" style="margin-top: var(--leveler-spacing-md);">
              <i class="fa-solid fa-circle-info"></i>
              {{this.prompt}}
            </div>
            {{#if (eq this.choiceType "skill")}}
            <div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <button type="button" class="skill-btn {{#if this.selected}}selected{{/if}}" data-action="selectPlannedFeatChoice" data-category="ancestryFeats" data-flag="{{../flag}}" data-value="{{this.value}}" data-grants-skill-training="{{#if ../grantsSkillTraining}}true{{else}}false{{/if}}" {{#if this.disabled}}disabled{{/if}}>
                <span class="skill-btn__name">{{this.label}}</span>
              </button>
              {{/each}}
            </div>
            {{else if (eq this.choiceType "language")}}
            <div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <button type="button" class="skill-btn skill-btn--stacked {{#if this.selected}}selected{{/if}} {{#if this.isDisallowed}}wizard-item--disallowed{{/if}}" data-action="selectPlannedFeatChoice" data-category="ancestryFeats" data-flag="{{../flag}}" data-value="{{this.value}}" {{#if this.isDisallowed}}disabled{{/if}}>
                <span class="skill-btn__content">
                  <span class="skill-btn__name">{{this.label}}</span>
                  <span class="skill-btn__tags">
                    {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
                    {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
                    {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
                    {{#if this.suggested}}<span class="tag tag--info tag--tiny">{{localize "PF2E_LEVELER.CREATION.ANCESTRY_SUGGESTION"}}</span>{{/if}}
                    {{#if (notEqual this.rarity "common")}}<span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>{{/if}}
                  </span>
                </span>
              </button>
              {{/each}}
            </div>
            {{else if (eq this.choiceType "lore")}}
            {{#if this.options.length}}<div class="skill-btn-grid" style="margin-top: var(--leveler-spacing-sm);">{{#each this.options}}<button type="button" class="skill-btn {{#if this.selected}}selected{{/if}}" disabled><span class="skill-btn__name">{{this.label}}</span></button>{{/each}}</div>{{/if}}

            {{else}}
            <div class="wizard-item-grid wizard-item-grid--compact" style="margin-top: var(--leveler-spacing-sm);">
              {{#each this.options}}
              <div class="wizard-item {{#if this.selected}}wizard-item--taken{{/if}}">
                {{#if this.img}}
                <img src="{{this.img}}" alt="" class="wizard-item__img">
                {{/if}}
                <div class="wizard-item__info">
                  <span class="wizard-item__name wizard-item__name--static">{{this.label}}</span>
                </div>
                {{#if this.selected}}
