<div class="pf2e-leveler feat-picker spell-picker">
  <div class="feat-picker__filters">
    <input type="text" class="feat-picker__search"
           placeholder="{{localize 'PF2E_LEVELER.SPELLS.SEARCH'}}"
           data-action="searchSpells">
  </div>
  <div class="spell-picker__secondary-filters">
    <div class="wizard-trait-input spell-picker__trait-input">
      <span class="wizard-trait-chips" data-target="spells"></span>
      <input type="text" class="wizard-trait-input__field" placeholder="{{localize 'PF2E_LEVELER.SPELLS.TRAIT_FILTER'}}" data-action="traitInput" data-target="spells" list="spell-trait-options">
    </div>
    <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="uncommon" checked> {{localize "PF2E.TraitUncommon"}}</label>
    <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="rare" checked> {{localize "PF2E.TraitRare"}}</label>
  </div>

  <div class="feat-list spell-list">
    {{#each spells}}
    <div class="feat-option spell-option" data-uuid="{{this.uuid}}" data-traits="{{this.system.traits.value}}" data-rarity="{{this.system.traits.rarity}}">
      <img class="feat-option__img" src="{{this.img}}" alt="">
      <div class="feat-option__info">
        <div class="feat-option__header">
          <span class="feat-option__name" data-action="viewSpell">{{this.name}}</span>
          <span class="feat-option__level">{{localize "PF2E_LEVELER.SPELLS.RANK"}} {{this.system.level.value}}</span>
        </div>
        <div class="feat-option__traits">
          {{#each this.system.traits.value}}
          <span class="tag tag--muted" data-tooltip="{{titleCase this}}">{{this}}</span>
          {{/each}}
          {{#if (notEqual this.system.traits.rarity "common")}}
          <span class="tag tag--rarity-{{this.system.traits.rarity}}">{{this.system.traits.rarity}}</span>
          {{/if}}
        </div>
      </div>
      <div class="feat-option__actions">
        <button type="button" class="feat-option__select-btn" data-action="selectSpell" data-uuid="{{this.uuid}}">
          {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
        </button>
      </div>
    </div>
    {{else}}
    <div class="planner-empty" style="padding: 2rem;">
      <p>{{localize "PF2E_LEVELER.FEAT_PICKER.NO_RESULTS"}}</p>
    </div>
    {{/each}}
  </div>

  <datalist id="spell-trait-options">
    {{#each traitOptions}}
    <option value="{{this}}">
    {{/each}}
  </datalist>
</div>
