<div class="pf2e-leveler spell-picker">
  <div class="picker__browser">
    <aside class="picker__sidebar">
      {{#if selectedSpells.length}}
      <div class="picker__filter-group picker__filter-group--compact">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.SPELLS.ALREADY_SELECTED"}} ({{selectedSpells.length}})</div>
        <div class="spell-picker__selected-sidebar picker__selected-sidebar">
          {{#each selectedSpells}}
          <div class="spell-picker__selected-sidebar-item">
            <img src="{{this.img}}" alt="" class="spell-picker__selected-sidebar-img">
            <button type="button" class="spell-picker__selected-sidebar-name" data-action="viewSpell" data-uuid="{{this.uuid}}">
              {{this.name}}
            </button>
            {{#if this.displayRankLabel}}
            <span class="tag tag--muted tag--tiny">{{this.displayRankLabel}}</span>
            {{/if}}
            {{#if this.canRemove}}
            <button type="button" class="spell-picker__selected-sidebar-remove" data-action="removeSelectedSpell" data-index="{{this.index}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.REMOVE'}}">
              <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}
      <div class="picker__filter-group picker__filter-group--compact">
        <input type="text" class="picker__search"
               placeholder="{{localize 'PF2E_LEVELER.SPELLS.SEARCH'}}"
               data-action="searchSpells">
      </div>

      <div class="picker__filter-group picker__filter-group--compact">
        <div class="wizard-trait-input spell-picker__trait-input picker__trait-autocomplete-wrap">
          <input type="text" class="wizard-trait-input__field" placeholder="{{localize 'PF2E_LEVELER.SPELLS.TRAIT_FILTER'}}" data-action="traitInput" data-target="spells" autocomplete="off">
          <button type="button" class="picker__prereq-toggle" data-action="toggleTraitFilterMode">{{#if (eq traitFilterMode "exclude")}}HIDE{{else}}SHOW{{/if}}</button>
          <button type="button" class="picker__prereq-toggle" data-action="toggleTraitLogic">{{#if (eq traitLogic "and")}}AND{{else}}OR{{/if}}</button>
          <ul class="picker__trait-autocomplete" data-role="trait-autocomplete"></ul>
        </div>
        <div class="picker__source-list picker__source-list--compact" data-role="selected-trait-chips" {{#unless selectedTraitChips.length}}style="display:none"{{/unless}}>
          {{#each selectedTraitChips}}
          <button
            type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleTraitChip"
            data-mode="{{this.mode}}"
            data-trait="{{this.value}}">
            <span>{{this.label}}</span>
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
          {{/each}}
        </div>
      </div>

      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.SPELLS.FILTER_RARITY"}}</div>
        <div class="picker__source-list" data-role="rarity-chips">
          {{#each rarityOptions}}
          <button
            type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}} {{#if this.locked}}locked{{/if}}"
            data-action="toggleRarityChip"
            data-rarity="{{this.value}}"
            {{#if this.locked}}data-tooltip="{{localize "PF2E_LEVELER.UI.LOCKED_FILTER_HINT"}}"{{/if}}>
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>

      <div class="picker__filter-group">
        <div class="picker__utility-row picker__utility-row--inline-label">
          <div class="picker__filter-label">{{localize "PF2E_LEVELER.SPELLS.SORT"}}</div>
          <select class="picker__select picker__select--compact" data-action="changeSort">
            {{#each sortOptions}}
            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
      </div>

      {{#if categoryOptions.length}}
      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.SPELLS.CATEGORY_FILTER"}}</div>
        <div class="picker__source-list">
          {{#each categoryOptions}}
          <button
            type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}} {{#if this.locked}}locked{{/if}}"
            data-action="toggleSpellCategory"
            data-category="{{this.value}}"
            {{#if this.locked}}data-tooltip="{{localize "PF2E_LEVELER.UI.LOCKED_FILTER_HINT"}}"{{/if}}>
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if rankOptions.length}}
      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.SPELLS.RANK_FILTER"}}</div>
        <div class="picker__source-list">
          {{#each rankOptions}}
          <button
            type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}} {{#if this.locked}}locked{{/if}}"
            data-action="toggleSpellRank"
            data-rank="{{this.value}}"
            {{#if this.locked}}data-tooltip="{{localize "PF2E_LEVELER.UI.LOCKED_FILTER_HINT"}}"{{/if}}>
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if traditionOptions.length}}
      <div class="picker__filter-group">
        <div class="picker__filter-label">{{localize "PF2E_LEVELER.SPELLS.TRADITION_FILTER"}}</div>
        <div class="picker__source-list">
          {{#each traditionOptions}}
          <button
            type="button"
            class="picker__source-chip {{#if this.selected}}selected{{/if}} {{#if this.locked}}locked{{/if}}"
            data-action="toggleSpellTradition"
            data-tradition="{{this.value}}"
            {{#if this.locked}}data-tooltip="{{localize "PF2E_LEVELER.UI.LOCKED_FILTER_HINT"}}"{{/if}}>
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if publicationOptions.length}}
      <div class="picker__filter-group picker__filter-group--collapsible" data-section="publications">
        <button type="button"
                class="picker__section-toggle"
                data-action="toggleFilterSection"
                data-section="publications"
                aria-expanded="{{#if filterSections.publications.collapsed}}false{{else}}true{{/if}}">
          <span>{{localize "PF2E_LEVELER.UI.PUBLICATIONS"}}</span>
          <span class="picker__section-meta">
            <span class="picker__section-summary" data-section-summary="publications">
              {{#if filterSections.publications.activeCount}}({{filterSections.publications.summary}}){{/if}}
            </span>
            <i class="fa-solid fa-chevron-down picker__section-chevron" aria-hidden="true"></i>
          </span>
        </button>
        {{#unless filterSections.publications.collapsed}}
        <div class="picker__section-body">
          <input type="text" class="picker__search picker__search--compact" placeholder="{{localize 'PF2E_LEVELER.UI.SEARCH_PUBLICATIONS'}}" data-action="searchPublications">
          <div class="picker__source-list picker__source-list--stacked">
            {{#each publicationOptions}}
            <button
              type="button"
              class="picker__source-chip picker__source-chip--publication {{#if this.selected}}selected{{/if}}"
              data-action="togglePublication"
              data-publication="{{this.key}}"
              data-publication-name="{{this.label}}"
              data-tooltip="{{this.key}}">
              <span class="picker__source-chip-label">{{this.label}}</span>
            </button>
            {{/each}}
          </div>
        </div>
        {{/unless}}
      </div>
      {{/if}}
    </aside>

    <section class="picker__results">
      <div class="picker__results-header">
        <div class="picker__results-label">{{capitalize tradition}} {{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_CATEGORIES.SPELLS"}}</div>
        <div class="spell-picker__results-meta">
          {{#if multiSelect}}
          <div class="spell-picker__selected-count">{{format "PF2E_LEVELER.SPELLS.SELECTED_COUNT" count=selectedCount}}</div>
          <button type="button" class="spell-option__select-btn spell-picker__bulk-btn" data-action="toggleSelectAll" {{#unless filteredCount}}disabled{{/unless}}>
            {{#if allVisibleSelected}}
              {{localize "PF2E_LEVELER.SPELLS.DESELECT_ALL"}}
            {{else}}
              {{localize "PF2E_LEVELER.SPELLS.SELECT_ALL"}}
            {{/if}}
          </button>
          <button type="button" class="spell-option__select-btn spell-picker__confirm-btn" data-action="confirmSelection" {{#unless selectedCount}}disabled{{/unless}}>
            {{localize "PF2E_LEVELER.SPELLS.ADD_SELECTED"}}
          </button>
          {{/if}}
          <div class="picker__results-count">{{filteredCount}}</div>
        </div>
      </div>

      <div class="spell-list spell-picker__list">
        {{#each spells}}
        <div class="spell-option {{#if this._levelerSelected}}spell-option--selected{{/if}} {{#if this.alreadyTaken}}spell-option--taken{{/if}} {{#if this.guidanceSelectionBlocked}}wizard-item--disallowed{{/if}}" data-uuid="{{this.uuid}}" data-traits="{{this.system.traits.value}}" data-rarity="{{this.system.traits.rarity}}" data-already-taken="{{#if this.alreadyTaken}}true{{else}}false{{/if}}" data-selectable="{{#if this.selectionBlocked}}false{{else}}true{{/if}}">
          <img class="spell-option__img" src="{{this.img}}" alt="">
          <div class="spell-option__info">
            <div class="spell-option__header">
              <span class="spell-option__name" data-action="viewSpell">{{this.name}}</span>
              {{#if this.alreadyTaken}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.SPELLS.TAKEN"}}</span>{{/if}}
              <span class="spell-option__level">{{localize "PF2E_LEVELER.SPELLS.RANK"}} {{this.system.level.value}}</span>
            </div>
            <div class="spell-option__traits">
              {{#each this.system.traits.value}}
              <span class="tag tag--muted" data-tooltip="{{titleCase this}}">{{this}}</span>
              {{/each}}
              {{#if (notEqual this.system.traits.rarity "common")}}
              <span class="tag tag--rarity-{{this.system.traits.rarity}}">{{this.system.traits.rarity}}</span>
              {{/if}}
              {{#if this.isRecommended}}<span class="tag tag--success tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_RECOMMENDED"}}</span>{{/if}}
              {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
              {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
            </div>
          </div>
          <div class="spell-option__actions">
            <button type="button" class="spell-option__select-btn" data-action="selectSpell" data-uuid="{{this.uuid}}" {{#if this.selectionBlocked}}disabled{{/if}} data-tooltip="{{#if this.alreadyTaken}}{{localize 'PF2E_LEVELER.SPELLS.ALREADY_TAKEN'}}{{else if this.isDisallowed}}{{this.guidanceSelectionTooltip}}{{/if}}">
              {{#if this.alreadyTaken}}
                {{localize "PF2E_LEVELER.SPELLS.TAKEN"}}
              {{else if this.guidanceSelectionBlocked}}
                {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}
              {{else if ../multiSelect}}
                {{#if this._levelerSelected}}
                  {{localize "PF2E_LEVELER.UI.SELECTED"}}
                {{else}}
                  {{localize "PF2E_LEVELER.SPELLS.SELECT"}}
                {{/if}}
              {{else}}
                {{localize "PF2E_LEVELER.SPELLS.SELECT"}}
              {{/if}}
            </button>
          </div>
        </div>
        {{else}}
        <div class="planner-empty" style="padding: 2rem;">
          <p>{{localize "PF2E_LEVELER.SPELLS.NO_RESULTS"}}</p>
        </div>
        {{/each}}
      </div>
    </section>
  </div>

</div>
