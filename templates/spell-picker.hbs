<div class="pf2e-leveler feat-picker">
  <div class="feat-picker__filters">
    <input type="text" class="feat-picker__search"
           placeholder="{{localize 'PF2E_LEVELER.SPELLS.SEARCH'}}"
           data-action="searchSpells">
  </div>
  <div style="display: flex; align-items: center; gap: var(--leveler-spacing-md); padding: 0 var(--leveler-spacing-md); margin-bottom: var(--leveler-spacing-xs);">
    <div class="wizard-trait-input" style="flex: 1;">
      <span class="wizard-trait-chips" data-target="spells"></span>
      <input type="text" class="wizard-trait-input__field" placeholder="Type trait to filter..." data-action="traitInput" data-target="spells" list="spell-trait-options">
    </div>
    <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="uncommon" checked> Uncommon</label>
    <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="rare" checked> Rare</label>
  </div>

  <div class="feat-list spell-list">
    {{#each spells}}
    <div class="feat-option spell-option {{#if this.alreadyKnown}}feat-option--taken{{/if}}" data-uuid="{{this.uuid}}" data-traits="{{this.system.traits.value}}" data-rarity="{{this.system.traits.rarity}}">
      <img class="feat-option__img" src="{{this.img}}" alt="">
      <div class="feat-option__info">
        <div class="feat-option__header">
          <span class="feat-option__name" data-action="viewSpell">{{this.name}}</span>
          {{#if this.alreadyKnown}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-check"></i> Known</span>{{/if}}
          <span class="feat-option__level">Rank {{this.system.level.value}}</span>
        </div>
        <div class="feat-option__traits">
          {{#each this.system.traits.value}}
          <span class="tag tag--muted" data-tooltip="{{titleCase this}}">{{this}}</span>
          {{/each}}
          {{#if (notEqual this.system.traits.rarity "common")}}
          <span class="tag tag--rarity-{{this.system.traits.rarity}}">{{this.system.traits.rarity}}</span>
          {{/if}}
        </div>
      </div>
      <div class="feat-option__actions">
        <button type="button" class="feat-option__select-btn" data-action="selectSpell" data-uuid="{{this.uuid}}">
          {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
        </button>
      </div>
    </div>
    {{else}}
    <div class="planner-empty" style="padding: 2rem;">
      <p>{{localize "PF2E_LEVELER.FEAT_PICKER.NO_RESULTS"}}</p>
    </div>
    {{/each}}
  </div>

  <datalist id="spell-trait-options">
    {{#each traitOptions}}
    <option value="{{this}}">
    {{/each}}
  </datalist>
</div>
