<div class="pf2e-leveler feat-picker">
  <div class="feat-picker__browser">
    <aside class="feat-picker__sidebar">
      <div class="feat-picker__filter-group">
        <div class="feat-picker__filter-label">{{localize "PF2E_LEVELER.CREATION.SEARCH"}}</div>
        <input type="text" class="feat-picker__search"
               placeholder="{{localize 'PF2E_LEVELER.FEAT_PICKER.SEARCH'}}"
               data-action="searchFeats">
      </div>

      <div class="feat-picker__filter-group">
        <div class="feat-picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.SORT"}}</div>
        <select data-action="sortFeats" class="feat-picker__select">
          <option value="LEVEL_DESC" {{#if (eq sortMethod "LEVEL_DESC")}}selected{{/if}}>{{localize "PF2E_LEVELER.SETTINGS.FEAT_SORT.LEVEL_DESC"}}</option>
          <option value="LEVEL_ASC" {{#if (eq sortMethod "LEVEL_ASC")}}selected{{/if}}>{{localize "PF2E_LEVELER.SETTINGS.FEAT_SORT.LEVEL_ASC"}}</option>
          <option value="ALPHA_ASC" {{#if (eq sortMethod "ALPHA_ASC")}}selected{{/if}}>{{localize "PF2E_LEVELER.SETTINGS.FEAT_SORT.ALPHA_ASC"}}</option>
          <option value="ALPHA_DESC" {{#if (eq sortMethod "ALPHA_DESC")}}selected{{/if}}>{{localize "PF2E_LEVELER.SETTINGS.FEAT_SORT.ALPHA_DESC"}}</option>
        </select>
      </div>

      {{#if showSkillFilter}}
      <div class="feat-picker__filter-group">
        <div class="feat-picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.ALL_SKILLS"}}</div>
        <select data-action="filterSkillFeats" class="feat-picker__select">
          <option value="">{{localize "PF2E_LEVELER.FEAT_PICKER.ALL_SKILLS"}}</option>
          {{#each skillOptions}}
          <option value="{{this.slug}}" {{#if (eq ../selectedSkill this.slug)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      <div class="feat-picker__filter-group">
        <div class="feat-picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.FILTER_RARITY"}}</div>
        <div class="feat-picker__rarity-filters">
          <label class="feat-picker__check">
            <input type="checkbox" data-action="toggleUncommon" {{#if showUncommon}}checked{{/if}}>
            {{localize "PF2E.TraitUncommon"}}
          </label>
          <label class="feat-picker__check">
            <input type="checkbox" data-action="toggleRare" {{#if showRare}}checked{{/if}}>
            {{localize "PF2E.TraitRare"}}
          </label>
        </div>
      </div>

      <div class="feat-picker__filter-group">
        <div class="feat-picker__filter-label">{{localize "PF2E_LEVELER.FEAT_PICKER.OPTIONS"}}</div>
        <div class="feat-picker__toggle-list">
          <button type="button" class="feat-picker__prereq-toggle {{#if hideFailedPrereqs}}active{{/if}}" data-action="togglePrereqFilter" data-tooltip="{{localize 'PF2E_LEVELER.FEAT_PICKER.HIDE_UNMET'}}">
            <i class="fa-solid fa-filter"></i>
            {{localize "PF2E_LEVELER.FEAT_PICKER.ELIGIBLE_ONLY"}}
          </button>
          {{#if showDedicationToggle}}
          <button type="button" class="feat-picker__prereq-toggle {{#if showDedications}}active{{/if}}" data-action="toggleDedications">
            <i class="fa-solid fa-diagram-project"></i>
            {{localize "PF2E_LEVELER.FEAT_PICKER.DEDICATIONS"}}
          </button>
          {{/if}}
          {{#if showGeneralSkillToggle}}
          <button type="button" class="feat-picker__prereq-toggle {{#if showSkillFeats}}active{{/if}}" data-action="toggleGeneralSkillFeats">
            <i class="fa-solid fa-screwdriver-wrench"></i>
            {{localize "PF2E_LEVELER.FEAT_PICKER.SKILL_FEATS"}}
          </button>
          {{/if}}
        </div>
      </div>

      {{#if sourceOptions.length}}
      <div class="feat-picker__filter-group">
        <div class="feat-picker__filter-label">{{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SUMMARY"}}</div>
        <input type="text" class="feat-picker__search" placeholder="{{localize 'PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SEARCH'}}" data-action="searchCompendiumSources">
        <div class="feat-picker__source-list">
          {{#each sourceOptions}}
          <button
            type="button"
            class="feat-picker__source-chip {{#if this.selected}}selected{{/if}}"
            data-action="toggleCompendiumSource"
            data-package="{{this.key}}"
            data-source-name="{{this.label}}"
            data-tooltip="{{this.key}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </aside>

    <section class="feat-picker__results">
      <div class="feat-picker__results-header">
        <div class="feat-picker__results-label">{{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_CATEGORIES.FEATS"}}</div>
        <div class="feat-picker__results-count">{{filteredCount}}</div>
      </div>

      <div class="feat-list">
        {{#each feats}}
        <div class="feat-option {{#if this.selectionBlocked}}feat-option--dimmed{{/if}} {{#if this.alreadyTaken}}feat-option--taken{{/if}}"
             data-uuid="{{this.uuid}}">
          <img class="feat-option__img" src="{{this.img}}" alt="">
          <div class="feat-option__info">
            <div class="feat-option__header">
              <span class="feat-option__name" data-action="viewFeat">{{this.name}}</span>
              {{#if this.alreadyTaken}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.FEAT_PICKER.TAKEN"}}</span>{{/if}}
              <span class="feat-option__level">{{format "PF2E_LEVELER.FEAT_PICKER.LEVEL" level=this.system.level.value}}</span>
            </div>
            <div class="feat-option__traits">
              {{#each this.system.traits.value}}
              <span class="tag tag--muted">{{this}}</span>
              {{/each}}
              {{#if (notEqual this.system.traits.rarity "common")}}
              <span class="tag tag--rarity-{{this.system.traits.rarity}}">{{this.system.traits.rarity}}</span>
              {{/if}}
            </div>
            {{#if this.prereqResults.length}}
            <div class="prereq-tags">
              {{#each this.prereqResults}}
              {{#if (eq this.met true)}}
                <span class="tag tag--success" data-tooltip="{{titleCase this.text}}"><i class="fa-solid fa-check"></i> {{titleCase this.text}}</span>
              {{else if (eq this.met false)}}
                <span class="tag tag--error" data-tooltip="{{titleCase this.text}}"><i class="fa-solid fa-xmark"></i> {{titleCase this.text}}</span>
              {{else}}
                <span class="tag tag--muted" data-tooltip="{{localize 'PF2E_LEVELER.FEAT_PICKER.PREREQ_UNVERIFIED_HINT'}}"><i class="fa-solid fa-question"></i> {{localize "PF2E_LEVELER.FEAT_PICKER.PREREQ_UNVERIFIED"}}: {{titleCase this.text}}</span>
              {{/if}}
              {{/each}}
            </div>
            {{/if}}
          </div>
          <div class="feat-option__actions">
            <button type="button" class="feat-option__chat-btn" data-action="sendToChat" data-uuid="{{this.uuid}}" data-tooltip="{{localize 'PF2E_LEVELER.FEAT_PICKER.SEND_TO_CHAT'}}">
              <i class="fa-solid fa-comment"></i>
            </button>
            {{#if this.alreadyTaken}}
              <button type="button" class="feat-option__select-btn" disabled data-tooltip="{{#if this.takenAtLevel}}Taken at level {{this.takenAtLevel}} â€” {{/if}}{{localize 'PF2E_LEVELER.FEAT_PICKER.ALREADY_TAKEN'}}">Taken</button>
            {{else}}
              <button type="button" class="feat-option__select-btn" data-action="selectFeat" data-uuid="{{this.uuid}}" {{#if this.selectionBlocked}}disabled{{/if}} data-tooltip="{{#if this.selectionBlocked}}{{localize 'PF2E_LEVELER.FEAT_PICKER.PREREQ_UNMET_BLOCKED'}}{{else if this.hasUnknownPrerequisites}}{{localize 'PF2E_LEVELER.FEAT_PICKER.PREREQ_UNVERIFIED_HINT'}}{{/if}}">
                {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
              </button>
            {{/if}}
          </div>
        </div>
        {{else}}
        <div class="planner-empty" style="padding: 2rem;">
          <p>{{localize "PF2E_LEVELER.FEAT_PICKER.NO_RESULTS"}}</p>
        </div>
        {{/each}}
      </div>
    </section>
  </div>
</div>
