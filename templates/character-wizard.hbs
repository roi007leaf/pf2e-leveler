<div class="pf2e-leveler character-wizard">
  {{#if isApplying}}
  <div class="wizard-apply-overlay">
    <div class="wizard-apply-card">
      <div class="wizard-apply-card__scroll">
      <div class="wizard-apply-card__eyebrow">{{localize "PF2E_LEVELER.CREATION.APPLY_OVERLAY.EYEBROW"}}</div>
      <div class="wizard-apply-card__title">{{data.class.name}}{{#if data.subclass}} · {{data.subclass.name}}{{/if}}</div>
      <div class="wizard-apply-card__status">{{applyStatus}}</div>
      <div class="wizard-apply-card__bar">
        <div class="wizard-apply-card__fill" style="width: {{applyProgressPercent}}%;"></div>
      </div>
      <div class="wizard-apply-card__percent">{{applyProgressPercent}}%</div>
      {{#if activeApplyPrompt}}
      <div class="wizard-apply-card__section">
        <div class="wizard-apply-card__section-title">{{localize "PF2E_LEVELER.CREATION.APPLY_OVERLAY.CURRENT_PROMPT"}}</div>
        <div class="wizard-apply-card__rows">
          <div class="wizard-apply-card__row">
            <div class="wizard-apply-card__label">{{localize "PF2E_LEVELER.CREATION.APPLY_OVERLAY.PROMPT"}}</div>
            <div class="wizard-apply-card__value">{{activeApplyPrompt.prompt}}</div>
          </div>
          <div class="wizard-apply-card__row">
            <div class="wizard-apply-card__label">{{localize "PF2E_LEVELER.CREATION.APPLY_OVERLAY.USE"}}</div>
            <div class="wizard-apply-card__value">{{activeApplyPrompt.value}}</div>
          </div>
          <div class="wizard-apply-card__row">
            <div class="wizard-apply-card__label">{{localize "PF2E_LEVELER.CREATION.APPLY_OVERLAY.SOURCE"}}</div>
            <div class="wizard-apply-card__value">{{activeApplyPrompt.label}}</div>
          </div>
        </div>
      </div>
      {{/if}}
        {{#if applyPromptRows.length}}
        <div class="wizard-apply-card__section">
        <div class="wizard-apply-card__section-title">{{localize "PF2E_LEVELER.CREATION.APPLY_OVERLAY.USE_IN_PROMPTS"}}</div>
        <div class="wizard-apply-card__rows">
          {{#each applyPromptRows}}
          <div class="wizard-apply-card__row">
            <div class="wizard-apply-card__label">{{#if this.prompt}}{{this.prompt}}{{else}}{{this.label}}{{/if}}</div>
            <div class="wizard-apply-card__value">{{this.value}}{{#unless this.pending}}{{#if this.label}} <span class="wizard-apply-card__hint">({{this.label}})</span>{{/if}}{{/unless}}</div>
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}
      </div>
    </div>
  </div>
  {{/if}}
  <div class="wizard-sidebar">
    <div class="sidebar-header">
      {{localize "PF2E_LEVELER.CREATION.TITLE"}}
    </div>
    <div class="wizard-steps">
      {{#each steps}}
      <div class="wizard-step {{#if this.active}}active{{/if}} {{#if this.complete}}complete{{/if}}"
           data-action="goToStep" data-step="{{this.index}}">
        <span class="wizard-step__num">{{#if this.complete}}<i class="fa-solid fa-check"></i>{{else}}{{@index}}{{/if}}</span>
        <span class="wizard-step__label">{{this.label}}</span>
      </div>
      {{/each}}
    </div>
  </div>

  <div class="wizard-content">
    <div class="wizard-main">
    {{#if isBooting}}
    <div class="wizard-loading">
      <div class="wizard-loading__card">
        <div class="wizard-loading__spinner" aria-hidden="true"></div>
        <div class="wizard-loading__title">{{localize "PF2E_LEVELER.CREATION.TITLE"}}</div>
        <div class="wizard-loading__text">{{localize "PF2E_LEVELER.CREATION.LOADING"}}</div>
      </div>
    </div>
    {{else}}
    {{#if browserStep}}
    <div class="wizard-browser">
      <aside class="wizard-browser__filters">
        <h2>{{browserStep.title}}</h2>

        {{#if browserStep.selected}}
        <div class="wizard-selected wizard-selected--browser">
          <img src="{{browserStep.selected.img}}" alt="" class="wizard-selected__img">
          <div class="wizard-selected__stack">
            <span class="wizard-selected__label">{{localize "PF2E_LEVELER.UI.SELECTED"}}</span>
            <span class="wizard-selected__name" data-action="viewItem" data-uuid="{{browserStep.selected.uuid}}">{{browserStep.selected.name}}</span>
          </div>
          {{#if browserStep.selected.tradition}}
          <span class="tag tag--info tag--tiny">{{browserStep.selected.tradition}}</span>
          {{/if}}
          <i class="wizard-selected__clear fa-solid fa-xmark" data-action="{{browserStep.clearAction}}" data-tooltip="{{localize 'PF2E_LEVELER.UI.CLEAR'}}"></i>
        </div>
        {{/if}}

        {{#if browserStep.showSearch}}
        <div class="wizard-browser-filter">
          <div class="wizard-browser-filter__label">{{localize "PF2E_LEVELER.CREATION.SEARCH"}}</div>
          <input type="text" class="feat-picker__search" placeholder="{{localize 'PF2E_LEVELER.CREATION.SEARCH'}}" data-action="searchItems">
        </div>
        {{/if}}

        {{#if browserStep.showRarityFilters}}
        <div class="wizard-browser-filter">
          <div class="wizard-browser-filter__label">{{localize "PF2E_LEVELER.FEAT_PICKER.FILTER_RARITY"}}</div>
          <div class="wizard-rarity-filters wizard-rarity-filters--stacked">
            <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="uncommon" checked> {{localize "PF2E.TraitUncommon"}}</label>
            <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="rare" checked> {{localize "PF2E.TraitRare"}}</label>
          </div>
        </div>
        {{/if}}

        {{#if hasCompendiumSourceFilter}}
        <div class="wizard-browser-filter">
          <div class="wizard-browser-filter__label">{{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SUMMARY"}}</div>
          <input
            type="text"
            class="feat-picker__search wizard-source-filters__search"
            placeholder="{{localize 'PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SEARCH'}}"
            data-action="searchCompendiumSources">
          <div class="wizard-source-filters wizard-source-filters--sidebar">
            <div class="wizard-source-filters__chips">
              {{#each compendiumSourceOptions}}
              <button
                type="button"
                class="wizard-source-filter {{#if this.selected}}selected{{/if}}"
                data-action="toggleCompendiumSource"
                data-pack="{{this.key}}"
                data-tooltip="{{this.key}}"
                data-source-name="{{this.label}}">
                {{this.label}}
              </button>
              {{/each}}
            </div>
          </div>
        </div>
        {{/if}}
      </aside>

      <section class="wizard-browser__results">
        <div class="wizard-browser__results-header">
          <div class="wizard-browser__eyebrow">{{browserStep.resultsLabel}}</div>
          <div class="wizard-browser__count">{{browserStep.items.length}}</div>
        </div>

        <div class="wizard-item-grid wizard-item-grid--browser">
          {{#each browserStep.items}}
          <div class="wizard-item" data-name="{{this.name}}" data-rarity="{{this.rarity}}">
            <img src="{{this.img}}" alt="" class="wizard-item__img">
            <div class="wizard-item__info">
              <span class="wizard-item__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
              <div class="wizard-item__traits">
                {{#if ../browserStep.showTraits}}
                  {{#each this.traits}}
                  <span class="tag tag--muted tag--tiny" data-tooltip="{{titleCase this}}">{{this}}</span>
                  {{/each}}
                {{/if}}
                {{#if this.tradition}}
                <span class="tag tag--info tag--tiny">{{this.tradition}}</span>
                {{/if}}
                {{#if (notEqual this.rarity "common")}}
                <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
                {{/if}}
              </div>
            </div>
            <button
              type="button"
              class="wizard-item__select"
              data-action="{{../browserStep.selectAction}}"
              data-uuid="{{this.uuid}}"
              {{#if (eq ../browserStep.stepId "subclass")}}
              data-tradition="{{this.tradition}}"
              data-spelluuids='{{json this.spellUuids}}'
              data-skills='{{json this.grantedSkills}}'
              data-lores='{{json this.grantedLores}}'
              data-choicesets='{{json this.choiceSets}}'
              data-curriculum='{{json this.curriculum}}'
              {{/if}}>
              {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
            </button>
          </div>
          {{/each}}
        </div>
      </section>
    </div>
    {{else}}
    {{#unless (eq stepId "feats")}}
    {{#unless (eq stepId "spells")}}
    {{#if showGlobalCompendiumSourceFilter}}
    <div class="wizard-source-filters">
      <div class="wizard-source-filters__label">{{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SUMMARY"}}</div>
      <input
        type="text"
        class="feat-picker__search wizard-source-filters__search"
        placeholder="{{localize 'PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SEARCH'}}"
        data-action="searchCompendiumSources">
      <div class="wizard-source-filters__chips">
        {{#each compendiumSourceOptions}}
        <button
          type="button"
          class="wizard-source-filter {{#if this.selected}}selected{{/if}}"
          data-action="toggleCompendiumSource"
          data-pack="{{this.key}}"
          data-tooltip="{{this.key}}"
          data-source-name="{{this.label}}">
          {{this.label}}
        </button>
        {{/each}}
      </div>
    </div>
    {{/if}}
    {{/unless}}
    {{/unless}}

    {{#if (eq stepId "subclassChoices")}}
      <h2>{{subclassName}} Options</h2>

      {{#each choiceSets}}
      <div class="section-header" style="margin-top: var(--leveler-spacing-md);">
        <i class="section-header__icon fa-solid fa-list-check"></i>
        {{this.prompt}}
      </div>
      {{#if this.isItemChoice}}
      <div class="wizard-item-grid wizard-item-grid--compact">
        {{#each this.options}}
        <div class="wizard-item {{#if this.selected}}wizard-item--taken{{/if}}" data-name="{{this.label}} {{this.traits}}" data-rarity="{{this.rarity}}">
          {{#if this.img}}
          <img src="{{this.img}}" alt="" class="wizard-item__img">
          {{/if}}
          <div class="wizard-item__info">
            <span class="wizard-item__name {{#unless this.uuid}}wizard-item__name--static{{/unless}}" {{#if this.uuid}}data-action="viewItem" data-uuid="{{this.uuid}}"{{/if}}>{{this.label}}</span>
            {{#if this.summary}}
            <div class="wizard-item__desc">{{this.summary}}</div>
            {{/if}}
            <div class="wizard-item__traits">
              {{#each this.traits}}
              <span class="tag tag--muted tag--tiny" data-tooltip="{{titleCase this}}">{{this}}</span>
              {{/each}}
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
              {{/if}}
            </div>
          </div>
          {{#if this.selected}}
            <span class="tag tag--success tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.UI.SELECTED"}}</span>
          {{else}}
            <button type="button"
              class="wizard-item__select"
              data-action="selectSubclassChoice" data-flag="{{../flag}}" data-value="{{this.value}}">
              {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
            </button>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="skill-btn-grid">
        {{#each this.options}}
        <button type="button"
          class="skill-btn wizard-choice-btn {{#if this.selected}}selected{{/if}}"
          data-action="selectSubclassChoice" data-flag="{{../flag}}" data-value="{{this.value}}" {{#if this.disabled}}disabled{{/if}}>
          <span class="skill-btn__content">
            <span class="skill-btn__name">{{this.label}}</span>
            {{#if this.selectedInSkills}}
            <span class="skill-btn__hint">Selected in Skills</span>
            {{else if this.autoTrained}}
            <span class="skill-btn__hint">Already trained from {{this.autoTrainedSource}}</span>
            {{/if}}
          </span>
        </button>
        {{/each}}
      </div>
      {{/if}}
      {{/each}}

    {{else if (eq stepId "featChoices")}}
      <h2>{{localize "PF2E_LEVELER.CREATION.FEAT_CHOICES"}}</h2>

      {{#each featChoiceSections}}
        <div class="section-header wizard-choice-source" style="margin-top: var(--leveler-spacing-md);">
          <i class="section-header__icon fa-solid fa-list-check"></i>
          {{this.featName}}
        </div>

      {{#each this.choiceSets}}
      <div class="wizard-choice-block">
      <div class="section-header" style="margin-top: var(--leveler-spacing-md);">
        <i class="section-header__icon fa-solid fa-list-check"></i>
        {{this.prompt}}
      </div>
      {{#if this.isItemChoice}}
      {{#if this.isWeaponChoice}}
      <div class="wizard-choice-filters">
        <input type="text" class="feat-picker__search wizard-choice-filters__search" placeholder="Filter weapons..." data-action="searchChoiceSetItems">
        <div class="wizard-choice-filters__buttons">
          <button type="button" class="skill-btn wizard-choice-filter selected" data-action="filterWeaponChoice" data-filter="all">All</button>
          <button type="button" class="skill-btn wizard-choice-filter" data-action="filterWeaponChoice" data-filter="melee">Melee</button>
          <button type="button" class="skill-btn wizard-choice-filter" data-action="filterWeaponChoice" data-filter="ranged">Ranged</button>
          <button type="button" class="skill-btn wizard-choice-filter" data-action="filterWeaponChoice" data-filter="simple">Simple</button>
          <button type="button" class="skill-btn wizard-choice-filter" data-action="filterWeaponChoice" data-filter="martial">Martial</button>
          <button type="button" class="skill-btn wizard-choice-filter" data-action="filterWeaponChoice" data-filter="advanced">Advanced</button>
        </div>
      </div>
      {{/if}}
      <div class="wizard-item-grid wizard-item-grid--compact">
        {{#each this.options}}
        <div class="wizard-item {{#if this.selected}}wizard-item--taken{{/if}}" data-name="{{this.label}} {{this.traits}}" data-rarity="{{this.rarity}}" data-type="{{this.type}}" data-category="{{this.category}}" data-is-ranged="{{#if this.isRanged}}true{{else}}false{{/if}}">
          {{#if this.img}}
          <img src="{{this.img}}" alt="" class="wizard-item__img">
          {{/if}}
          <div class="wizard-item__info">
            <span class="wizard-item__name {{#unless this.uuid}}wizard-item__name--static{{/unless}}" {{#if this.uuid}}data-action="viewItem" data-uuid="{{this.uuid}}"{{/if}}>{{this.label}}</span>
            {{#if this.summary}}
            <div class="wizard-item__desc">{{this.summary}}</div>
            {{/if}}
            <div class="wizard-item__traits">
              {{#each this.traits}}
              <span class="tag tag--muted tag--tiny" data-tooltip="{{titleCase this}}">{{this}}</span>
              {{/each}}
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
              {{/if}}
            </div>
          </div>
          {{#if this.selected}}
            <span class="tag tag--success tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.UI.SELECTED"}}</span>
          {{else}}
            <button type="button"
              class="wizard-item__select"
              data-action="selectFeatChoice" data-slot="{{../../slot}}" data-flag="{{../flag}}" data-value="{{this.value}}">
              {{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}
            </button>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="skill-btn-grid">
        {{#each this.options}}
        <button type="button"
          class="skill-btn wizard-choice-btn {{#if this.selected}}selected{{/if}}"
          data-action="selectFeatChoice" data-slot="{{../../slot}}" data-flag="{{../flag}}" data-value="{{this.value}}" {{#if this.disabled}}disabled{{/if}}>
          <span class="skill-btn__content">
            <span class="skill-btn__name">{{this.label}}</span>
            {{#if this.selectedInSkills}}
            <span class="skill-btn__hint">Selected in Skills</span>
            {{else if this.autoTrained}}
            <span class="skill-btn__hint">Already trained from {{this.autoTrainedSource}}</span>
            {{/if}}
          </span>
        </button>
        {{/each}}
      </div>
      {{/if}}
      </div>
      {{/each}}
      {{/each}}

    {{else if (eq stepId "implement")}}
      <h2>{{localize "PF2E_LEVELER.CREATION.WIZARD.IMPLEMENT"}}</h2>
      {{#if data.implement}}
        <div class="wizard-selected">
          <img src="{{data.implement.img}}" alt="" class="wizard-selected__img">
          <span class="wizard-selected__name" data-action="viewItem" data-uuid="{{data.implement.uuid}}">{{data.implement.name}}</span>
          <i class="wizard-selected__clear fa-solid fa-xmark" data-action="clearImplement" data-tooltip="{{localize 'PF2E_LEVELER.UI.CLEAR'}}"></i>
        </div>
      {{/if}}
      <input type="text" class="feat-picker__search" placeholder="{{localize 'PF2E_LEVELER.CREATION.SEARCH'}}" data-action="searchItems">
      <div class="wizard-rarity-filters">
        <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="uncommon" checked> {{localize "PF2E.TraitUncommon"}}</label>
        <label class="wizard-rarity-toggle"><input type="checkbox" data-action="toggleRarity" data-rarity="rare" checked> {{localize "PF2E.TraitRare"}}</label>
      </div>
      <div class="wizard-item-grid">
        {{#each items}}
        <div class="wizard-item" data-name="{{this.name}}" data-rarity="{{this.rarity}}">
          <img src="{{this.img}}" alt="" class="wizard-item__img">
          <div class="wizard-item__info">
            <span class="wizard-item__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
            <div class="wizard-item__traits">
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
              {{/if}}
            </div>
          </div>
          <button type="button" class="wizard-item__select" data-action="selectItem" data-uuid="{{this.uuid}}">{{localize "PF2E_LEVELER.FEAT_PICKER.SELECT"}}</button>
        </div>
        {{/each}}
      </div>

    {{else if (eq stepId "tactics")}}
      <h2>{{localize "PF2E_LEVELER.CREATION.WIZARD.TACTICS"}}</h2>
      <p class="wizard-hint">{{localize "PF2E_LEVELER.CREATION.WIZARD.TACTICS_HINT"}}</p>
      {{#if selectedTactics.length}}
      <div class="section-header" style="margin-top: var(--leveler-spacing-md);">
        <i class="section-header__icon fa-solid fa-list-check"></i>
        {{format "PF2E_LEVELER.CREATION.SELECTED_TACTICS" selected=selectedTacticsCount count=maxTactics}}
      </div>
      <div class="wizard-spell-chips">
        {{#each selectedTactics}}
        <span class="wizard-spell-chip">
          <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
          <span class="wizard-spell-chip__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
          <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="toggleTactic" data-uuid="{{this.uuid}}" data-name="{{this.name}}" data-img="{{this.img}}" data-max="{{../maxTactics}}"></i>
        </span>
        {{/each}}
      </div>
      {{/if}}
      {{#unless (eq selectedTactics.length maxTactics)}}
      <div class="section-header" style="margin-top: var(--leveler-spacing-md);">
        <i class="section-header__icon fa-solid fa-plus"></i>
        {{format "PF2E_LEVELER.CREATION.WIZARD.AVAILABLE_TACTICS" selected=selectedTacticsCount count=maxTactics}}
      </div>
      <input type="text" class="feat-picker__search" placeholder="{{localize 'PF2E_LEVELER.CREATION.SEARCH'}}" data-action="searchItems">
      <div class="wizard-item-grid wizard-item-grid--compact">
        {{#each tactics}}
        {{#unless this.selected}}
        <div class="wizard-item" data-name="{{this.name}}" data-rarity="{{this.rarity}}">
          <img src="{{this.img}}" alt="" class="wizard-item__img">
          <div class="wizard-item__info">
            <span class="wizard-item__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
            <div class="wizard-item__traits">
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
              {{/if}}
            </div>
          </div>
          <button type="button" class="wizard-item__select" data-action="toggleTactic" data-uuid="{{this.uuid}}" data-name="{{this.name}}" data-img="{{this.img}}" data-max="{{../maxTactics}}">+</button>
        </div>
        {{/unless}}
        {{/each}}
      </div>
      {{/unless}}

    {{else if (eq stepId "ikons")}}
      <h2>{{localize "PF2E_LEVELER.CREATION.WIZARD.IKONS"}}</h2>
      <p class="wizard-hint">{{localize "PF2E_LEVELER.CREATION.WIZARD.IKONS_HINT"}}</p>
      {{#if selectedIkons.length}}
      <div class="section-header" style="margin-top: var(--leveler-spacing-md);">
        <i class="section-header__icon fa-solid fa-gem"></i>
        {{format "PF2E_LEVELER.CREATION.SELECTED_IKONS" selected=selectedIkonsCount count=maxIkons}}
      </div>
      <div class="wizard-spell-chips">
        {{#each selectedIkons}}
        <span class="wizard-spell-chip">
          <img src="{{this.img}}" alt="" class="wizard-spell-chip__img">
          <span class="wizard-spell-chip__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
          <i class="fa-solid fa-xmark wizard-spell-chip__remove" data-action="toggleIkon" data-uuid="{{this.uuid}}" data-name="{{this.name}}" data-img="{{this.img}}" data-max="{{../maxIkons}}"></i>
        </span>
        {{/each}}
      </div>
      {{/if}}
      {{#unless (eq selectedIkons.length maxIkons)}}
      <div class="section-header" style="margin-top: var(--leveler-spacing-md);">
        <i class="section-header__icon fa-solid fa-plus"></i>
        {{format "PF2E_LEVELER.CREATION.WIZARD.AVAILABLE_IKONS" selected=selectedIkonsCount count=maxIkons}}
      </div>
      <input type="text" class="feat-picker__search" placeholder="{{localize 'PF2E_LEVELER.CREATION.SEARCH'}}" data-action="searchItems">
      <div class="wizard-item-grid wizard-item-grid--compact">
        {{#each ikons}}
        {{#unless this.selected}}
        <div class="wizard-item" data-name="{{this.name}}" data-rarity="{{this.rarity}}">
          <img src="{{this.img}}" alt="" class="wizard-item__img">
          <div class="wizard-item__info">
            <span class="wizard-item__name" data-action="viewItem" data-uuid="{{this.uuid}}">{{this.name}}</span>
            <div class="wizard-item__traits">
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
              {{/if}}
            </div>
          </div>
          <button type="button" class="wizard-item__select" data-action="toggleIkon" data-uuid="{{this.uuid}}" data-name="{{this.name}}" data-img="{{this.img}}" data-max="{{../maxIkons}}">+</button>
        </div>
        {{/unless}}
        {{/each}}
      </div>
      {{/unless}}

    {{else if (eq stepId "innovationDetails")}}
      <h2>{{localize "PF2E_LEVELER.CREATION.WIZARD.INNOVATION_DETAILS"}}</h2>
      {{#if innovationType}}
