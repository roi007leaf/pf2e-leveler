<section class="compendium-manager">
  <header class="compendium-manager__hero">
    <div>
      <h2 class="compendium-manager__title">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.NAME"}}</h2>
      <p class="compendium-manager__intro">{{intro}}</p>
    </div>
  </header>

  <div class="compendium-manager__tabs" role="tablist">
    <div class="compendium-manager__tabsGroup">
      {{#each primaryCategories}}
      <button
        type="button"
        class="compendium-manager__tab {{#if this.active}}is-active{{/if}}"
        data-action="select-category"
        data-category="{{this.key}}">
        <span class="compendium-manager__tabLabel">{{this.label}}</span>
        {{#if this.markedCount}}
        <span class="tag tag--info">{{this.markedCount}}</span>
        {{/if}}
      </button>
      {{/each}}
    </div>
    {{#if secondaryCategories.length}}
    <div class="compendium-manager__tabsGroup compendium-manager__tabsGroup--secondary">
      {{#each secondaryCategories}}
      <button
        type="button"
        class="compendium-manager__tab {{#if this.active}}is-active{{/if}}"
        data-action="select-category"
        data-category="{{this.key}}">
        <span class="compendium-manager__tabLabel">{{this.label}}</span>
        {{#if this.markedCount}}
        <span class="tag tag--info">{{this.markedCount}}</span>
        {{/if}}
      </button>
      {{/each}}
    </div>
    {{/if}}
  </div>

  <div class="compendium-manager__panelWrap">
    <section class="compendium-manager__panel">
      <header class="compendium-manager__panelHeader">
        <input
          type="text"
          class="compendium-manager__packSearch"
          placeholder="{{searchPlaceholder}}"
          value="{{searchText}}"
          data-action="search-guidance">
      </header>

      <section class="guidance-default-policy">
        <span class="guidance-bulk__title">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.DEFAULT_POLICY"}}</span>
        <div class="guidance-bulk__actions">
          {{#each categoryDefaultOptions}}
          <button
            type="button"
            class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{#if this.active}}is-active{{/if}}"
            data-action="set-category-default"
            data-policy="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </section>

      {{#if showClassArchetypeModeFilter}}
      <section class="guidance-mode-filter">
        <span class="guidance-bulk__title">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.CLASS_ARCHETYPE_VIEW"}}</span>
        <div class="guidance-bulk__actions">
          {{#each classArchetypeModeOptions}}
          <button
            type="button"
            class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{#if this.active}}is-active{{/if}}"
            data-action="set-class-archetype-mode"
            data-mode="{{this.value}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if specialBulkGroups.length}}
      <section class="guidance-bulk">
        <div class="guidance-bulk__title">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BULK_SPECIAL"}}</div>
        {{#each specialBulkGroups}}
        <div class="guidance-bulk__row">
          <span class="tag tag--info">{{this.label}} ({{this.count}})</span>
          <div class="guidance-bulk__actions guidance-bulk__actions--status">
            {{#each this.actions}}
            <button
              type="button"
              class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
              data-action="bulk-guidance"
              data-scope-type="{{../scopeType}}"
              data-scope-value="{{../scopeValue}}"
              data-status="{{this.status}}">
              {{this.label}}
            </button>
            {{/each}}
          </div>
        </div>
        {{/each}}
      </section>
      {{/if}}

      {{#if rarityBulkGroups.length}}
      <section class="guidance-bulk">
        <div class="guidance-bulk__title">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BULK_RARITY"}}</div>
        {{#each rarityBulkGroups}}
        <div class="guidance-bulk__row">
          <span class="tag tag--rarity-{{this.scopeValue}}">{{this.label}}</span>
          <div class="guidance-bulk__actions guidance-bulk__actions--status">
            {{#each this.actions}}
            <button
              type="button"
              class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
              data-action="bulk-guidance"
              data-scope-type="{{../scopeType}}"
              data-scope-value="{{../scopeValue}}"
              data-status="{{this.status}}">
              {{this.label}}
            </button>
            {{/each}}
          </div>
          <div class="guidance-bulk__actions guidance-bulk__actions--filter">
            {{#each this.exclusiveActions}}
            <button
              type="button"
              class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
              data-action="bulk-exclusive-guidance"
              data-scope-type="{{../scopeType}}"
              data-scope-value="{{../scopeValue}}"
              data-exclusive="{{this.exclusive}}">
              {{this.label}}
            </button>
            {{/each}}
          </div>
          {{#if this.showFreeArchetypeExclusiveActions}}
          <div class="guidance-bulk__actions guidance-bulk__actions--filter">
            {{#each this.freeArchetypeExclusiveActions}}
            <button
              type="button"
              class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
              data-action="bulk-free-archetype-exclusive-guidance"
              data-scope-type="{{../scopeType}}"
              data-scope-value="{{../scopeValue}}"
              data-free-archetype-exclusive="{{this.freeArchetypeExclusive}}">
              {{this.label}}
            </button>
            {{/each}}
          </div>
          {{/if}}
        </div>
        {{/each}}
      </section>
      {{/if}}

      {{#if publicationGroupBulkGroups.length}}
      <section class="guidance-bulk">
        <div class="guidance-bulk__title">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BULK_GROUP"}}</div>
        {{#each publicationGroupBulkGroups}}
        <div class="guidance-bulk__row">
          <span class="tag tag--info">{{this.label}} ({{this.count}})</span>
          <div class="guidance-bulk__actions guidance-bulk__actions--status">
            {{#each this.actions}}
            <button
              type="button"
              class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
              data-action="bulk-guidance"
              data-scope-type="{{../scopeType}}"
              data-scope-value="{{../scopeValue}}"
              data-status="{{this.status}}">
              {{this.label}}
            </button>
            {{/each}}
          </div>
        </div>
        {{/each}}
      </section>
      {{/if}}

      <div class="guidance-list {{#if useGridLayout}}guidance-list--grid{{/if}}">
        {{#if groupedItems}}
          {{#each groupedItems}}
          <div class="wizard-browser__group-label guidance-group__header">
            <span>{{this.label}}</span>
            <div class="guidance-bulk__actionGroups">
              <div class="guidance-bulk__actions guidance-bulk__actions--status">
                {{#each this.bulkActions}}
                <button
                  type="button"
                  class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
                  data-action="bulk-guidance"
                  data-scope-type="{{../bulkScopeType}}"
                  data-scope-value="{{../bulkScopeValue}}"
                  data-status="{{this.status}}">
                  {{this.label}}
                </button>
                {{/each}}
              </div>
              <div class="guidance-bulk__actions guidance-bulk__actions--filter">
                {{#each this.bulkExclusiveActions}}
                <button
                  type="button"
                  class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
                  data-action="bulk-exclusive-guidance"
                  data-scope-type="{{../bulkScopeType}}"
                  data-scope-value="{{../bulkScopeValue}}"
                  data-exclusive="{{this.exclusive}}">
                  {{this.label}}
                </button>
                {{/each}}
              </div>
              {{#if this.showFreeArchetypeExclusiveActions}}
              <div class="guidance-bulk__actions guidance-bulk__actions--filter">
                {{#each this.bulkFreeArchetypeExclusiveActions}}
                <button
                  type="button"
                  class="compendium-manager__button compendium-manager__button--small guidance-bulk__button {{this.className}}"
                  data-action="bulk-free-archetype-exclusive-guidance"
                  data-scope-type="{{../bulkScopeType}}"
                  data-scope-value="{{../bulkScopeValue}}"
                  data-free-archetype-exclusive="{{this.freeArchetypeExclusive}}">
                  {{this.label}}
                </button>
                {{/each}}
              </div>
              {{/if}}
            </div>
          </div>
            {{#each this.items}}
            <div class="guidance-item {{#if this.isRecommended}}guidance-item--recommended{{/if}} {{#if this.isDisallowed}}guidance-item--disallowed{{/if}}">
              {{#if this.img}}<img src="{{this.img}}" alt="" class="guidance-item__img">{{/if}}
              <div class="guidance-item__info">
                {{#if this.openable}}
                <button type="button" class="guidance-item__name guidance-item__name--link" data-action="viewGuidanceItem" data-uuid="{{this.uuid}}">{{this.name}}</button>
                {{else}}
                <span class="guidance-item__name">{{this.name}}</span>
                {{/if}}
                {{#if this.isAllowed}}<span class="tag tag--allowed tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_ALLOWED"}}</span>{{/if}}
                {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
                {{#if this.isExclusive}}<span class="tag tag--exclusive tag--tiny"><i class="fa-solid fa-filter"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_EXCLUSIVE"}}</span>{{/if}}
                {{#if this.showFreeArchetypeExclusiveControls}}{{#if this.isFreeArchetypeExclusive}}<span class="tag tag--free-archetype-exclusive tag--tiny"><i class="fa-solid fa-layer-group"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_FREE_ARCHETYPE_EXCLUSIVE"}}</span>{{/if}}{{/if}}
                {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
                {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
                {{#if this.guidanceInherited}}<span class="tag tag--info tag--tiny">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_INHERITED"}}</span>{{/if}}
                {{#if (notEqual this.rarity "common")}}
                <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
                {{/if}}
                {{#if this.level}}
                <span class="tag tag--muted tag--tiny">Lv {{this.level}}</span>
                {{/if}}
                {{#if this.matchedCount}}
                <span class="tag tag--muted tag--tiny">{{format "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.MATCHED_COUNT" count=this.matchedCount}}</span>
                {{/if}}
                {{#if this.categorySummary}}
                <span class="tag tag--info tag--tiny">{{this.categorySummary}}</span>
                {{/if}}
              </div>
              <button
                type="button"
                class="guidance-item__toggle {{#if this.isExclusive}}is-active{{/if}}"
                data-action="toggle-exclusive-guidance"
                data-uuid="{{this.uuid}}"
                data-tooltip="{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_EXCLUSIVE"}}">
                <i class="fa-solid fa-filter" style="{{#unless this.isExclusive}}opacity: 0.35;{{/unless}}"></i>
              </button>
              {{#if this.showFreeArchetypeExclusiveControls}}
              <button
                type="button"
                class="guidance-item__toggle {{#if this.isFreeArchetypeExclusive}}is-active is-free-archetype-exclusive{{/if}}"
                data-action="toggle-free-archetype-exclusive-guidance"
                data-uuid="{{this.uuid}}"
                data-tooltip="{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_FREE_ARCHETYPE_EXCLUSIVE"}}">
                <i class="fa-solid fa-layer-group" style="{{#unless this.isFreeArchetypeExclusive}}opacity: 0.35;{{/unless}}"></i>
              </button>
              {{/if}}
              <button
                type="button"
                class="guidance-item__toggle"
                data-action="cycle-guidance"
                data-uuid="{{this.uuid}}">
                {{#if this.isAllowed}}
                <i class="fa-solid fa-check" style="color: #63b66d;"></i>
                {{else if this.isRecommended}}
                <i class="fa-solid fa-star" style="color: #c4a747;"></i>
                {{else if this.isNotRecommended}}
                <i class="fa-solid fa-triangle-exclamation" style="color: #8a6d3b;"></i>
                {{else if this.isDisallowed}}
                <i class="fa-solid fa-ban" style="color: #aa3333;"></i>
                {{else}}
                <i class="fa-regular fa-circle" style="opacity: 0.4;"></i>
                {{/if}}
              </button>
            </div>
            {{/each}}
          {{/each}}
        {{else}}
          {{#each items}}
          <div class="guidance-item {{#if this.isRecommended}}guidance-item--recommended{{/if}} {{#if this.isDisallowed}}guidance-item--disallowed{{/if}}">
            {{#if this.img}}<img src="{{this.img}}" alt="" class="guidance-item__img">{{/if}}
            <div class="guidance-item__info">
              {{#if this.openable}}
              <button type="button" class="guidance-item__name guidance-item__name--link" data-action="viewGuidanceItem" data-uuid="{{this.uuid}}">{{this.name}}</button>
              {{else}}
              <span class="guidance-item__name">{{this.name}}</span>
              {{/if}}
              {{#if this.isAllowed}}<span class="tag tag--allowed tag--tiny"><i class="fa-solid fa-check"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_ALLOWED"}}</span>{{/if}}
              {{#if this.isRecommended}}<span class="tag tag--recommended tag--tiny"><i class="fa-solid fa-star"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_SUGGESTED"}}</span>{{/if}}
              {{#if this.isExclusive}}<span class="tag tag--exclusive tag--tiny"><i class="fa-solid fa-filter"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_EXCLUSIVE"}}</span>{{/if}}
              {{#if this.showFreeArchetypeExclusiveControls}}{{#if this.isFreeArchetypeExclusive}}<span class="tag tag--free-archetype-exclusive tag--tiny"><i class="fa-solid fa-layer-group"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_FREE_ARCHETYPE_EXCLUSIVE"}}</span>{{/if}}{{/if}}
              {{#if this.isNotRecommended}}<span class="tag tag--muted tag--tiny"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_NOT_RECOMMENDED"}}</span>{{/if}}
              {{#if this.isDisallowed}}<span class="tag tag--disallowed tag--tiny"><i class="fa-solid fa-ban"></i> {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_DISALLOWED"}}</span>{{/if}}
              {{#if this.guidanceInherited}}<span class="tag tag--info tag--tiny">{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_INHERITED"}}</span>{{/if}}
              {{#if (notEqual this.rarity "common")}}
              <span class="tag tag--rarity-{{this.rarity}} tag--tiny">{{this.rarity}}</span>
              {{/if}}
              {{#if this.level}}
              <span class="tag tag--muted tag--tiny">Lv {{this.level}}</span>
              {{/if}}
              {{#if this.matchedCount}}
              <span class="tag tag--muted tag--tiny">{{format "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.MATCHED_COUNT" count=this.matchedCount}}</span>
              {{/if}}
              {{#if this.categorySummary}}
              <span class="tag tag--info tag--tiny">{{this.categorySummary}}</span>
              {{/if}}
            </div>
            <button
              type="button"
              class="guidance-item__toggle {{#if this.isExclusive}}is-active{{/if}}"
              data-action="toggle-exclusive-guidance"
              data-uuid="{{this.uuid}}"
              data-tooltip="{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_EXCLUSIVE"}}">
              <i class="fa-solid fa-filter" style="{{#unless this.isExclusive}}opacity: 0.35;{{/unless}}"></i>
            </button>
            {{#if this.showFreeArchetypeExclusiveControls}}
            <button
              type="button"
              class="guidance-item__toggle {{#if this.isFreeArchetypeExclusive}}is-active is-free-archetype-exclusive{{/if}}"
              data-action="toggle-free-archetype-exclusive-guidance"
              data-uuid="{{this.uuid}}"
              data-tooltip="{{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.BADGE_FREE_ARCHETYPE_EXCLUSIVE"}}">
              <i class="fa-solid fa-layer-group" style="{{#unless this.isFreeArchetypeExclusive}}opacity: 0.35;{{/unless}}"></i>
            </button>
            {{/if}}
            <button
              type="button"
              class="guidance-item__toggle"
              data-action="cycle-guidance"
              data-uuid="{{this.uuid}}">
              {{#if this.isAllowed}}
              <i class="fa-solid fa-check" style="color: #63b66d;"></i>
              {{else if this.isRecommended}}
              <i class="fa-solid fa-star" style="color: #c4a747;"></i>
              {{else if this.isNotRecommended}}
              <i class="fa-solid fa-triangle-exclamation" style="color: #8a6d3b;"></i>
              {{else if this.isDisallowed}}
              <i class="fa-solid fa-ban" style="color: #aa3333;"></i>
              {{else}}
              <i class="fa-regular fa-circle" style="opacity: 0.4;"></i>
              {{/if}}
            </button>
          </div>
          {{/each}}
        {{/if}}
      </div>
    </section>
  </div>

  <footer class="compendium-manager__footer">
    <span class="compendium-manager__countLabel">{{countLabel}}</span>
    <button type="button" class="compendium-manager__button compendium-manager__button--ghost" data-action="clear-all-guidance">
      {{localize "PF2E_LEVELER.SETTINGS.CONTENT_GUIDANCE.CLEAR_ALL"}}
    </button>
    <button type="button" class="compendium-manager__button compendium-manager__button--ghost" data-action="close-guidance">
      {{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.CANCEL"}}
    </button>
    <button type="button" class="compendium-manager__button compendium-manager__button--primary" data-action="save-guidance">
      {{localize "PF2E_LEVELER.SETTINGS.COMPENDIUM_MANAGER.SAVE"}}
    </button>
  </footer>
</section>
