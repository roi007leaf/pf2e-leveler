{
  "name": "pf2e-leveler",
  "version": "3.4.3",
  "description": "Plan and auto-apply character level-ups for Pathfinder 2E",
  "main": "scripts/main.js",
  "scripts": {
    "test": "jest --maxWorkers=50%",
    "test:watch": "jest --maxWorkers=50% --watch",
    "test:coverage": "jest --coverage --maxWorkers=50%",
    "test:ci": "jest --ci --coverage --watchAll=false --maxWorkers=50%",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "echo 'No build step required for Foundry VTT modules'",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@eslint/js": "^9.35.0",
    "babel-jest": "^30.1.2",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "prettier": "^3.6.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/scripts/$1"
    },
    "collectCoverageFrom": [
      "scripts/**/*.js",
      "!scripts/**/*.test.js",
      "!scripts/main.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/scripts/**/*.test.js"
    ]
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
  "volta": {
    "node": "20.19.4"
  }
}
